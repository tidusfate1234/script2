-- // ========== WALL CHECK (RAYCAST WITH BLACKLIST) ==========
local function canSeeTarget(targetPart)
    if not Settings.WallCheck then return true end
    
    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin).Unit * (targetPart.Position - origin).Magnitude
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    -- BLACKLIST: Ignore local player and the target's character (so we only hit walls)
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, targetPart.Parent}
    
    local rayResult = workspace:Raycast(origin, direction, raycastParams)
    
    -- If ray hits nothing, target is visible
    -- If ray hits something that's NOT the target, it's behind a wall
    if not rayResult then
        return true
    end
    
    -- Check if the hit object is part of the target's character
    local hitCharacter = rayResult.Instance:FindFirstAncestor("Character")
    return hitCharacter == targetPart.Parent
end

-- // ========== HELPER FUNCTIONS ==========
local function isAlive(character)
    local humanoid = character:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

local function getValidAimPart(character)
    local part = character:FindFirstChild(Settings.AimPart)
    if part then return part end
    return character:FindFirstChild("HumanoidRootPart")
end

local function getClosestPlayer()
    local closest = nil
    local shortestDist = Settings.FOVRadius
    local mousePos = UserInputService:GetMouseLocation()
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then goto continue end
        if Settings.TeamCheck and player.Team == LocalPlayer.Team then goto continue end
        
        local character = player.Character
        if not character then goto continue end
        if not isAlive(character) then goto continue end
        
        local aimPart = getValidAimPart(character)
        if not aimPart then goto continue end
        
        -- Wall check (BLACKLIST)
        if not canSeeTarget(aimPart) then goto continue end
        
        local screenPoint, onScreen = Camera:WorldToScreenPoint(aimPart.Position)
        if not onScreen then goto continue end
        
        local distance = (Vector2.new(screenPoint.X, screenPoint.Y) - mousePos).Magnitude
        
        if distance < shortestDist then
            shortestDist = distance
            closest = player
        end
        
        ::continue::
    end
    
    return closest
end

-- // ========== AUTO SHOOT (TRIGGERBOT) ==========
local lastShotTime = 0
local function triggerbot(target)
    if not Settings.AutoShoot then return end
    if not target then return end
    
    -- Rate limit shooting (prevents spam)
    local now = tick()
    if now - lastShotTime < 0.05 then return end
    lastShotTime = now
    
    -- Simulate mouse click
    UserInputService:SetMouseButtonDown(Enum.UserInputType.MouseButton1)
    task.wait(0.02)
    UserInputService:SetMouseButtonUp(Enum.UserInputType.MouseButton1)
end

-- // ========== FOV CIRCLE ==========
local FOVCircle = nil
if Settings.ShowFOV and Drawing then
    FOVCircle = Drawing.new("Circle")
    FOVCircle.Thickness = 1.5
    FOVCircle.NumSides = 72
    FOVCircle.Color = Settings.FOVColor
    FOVCircle.Transparency = Settings.FOVTransparency
    FOVCircle.Filled = false
    FOVCircle.Visible = true
    FOVCircle.Radius = Settings.FOVRadius
end

-- // ========== MAIN AIMBOT LOOP ==========
local currentTarget = nil

RunService.RenderStepped:Connect(function()
    -- Update FOV Circle
    if FOVCircle then
        FOVCircle.Position = UserInputService:GetMouseLocation()
        FOVCircle.Radius = Settings.FOVRadius
        FOVCircle.Color = Settings.FOVColor
        FOVCircle.Transparency = Settings.FOVTransparency
        FOVCircle.Visible = Settings.ShowFOV and Settings.AimbotEnabled
    end
    
    if not Settings.AimbotEnabled then return end
    
    -- Get closest target
    currentTarget = getClosestPlayer()
    
    if currentTarget then
        local character = currentTarget.Character
        if character then
            local aimPart = getValidAimPart(character)
            if aimPart then
                -- Smooth camera movement
                local targetCFrame = CFrame.new(Camera.CFrame.Position, aimPart.Position)
                if Settings.Smoothness > 0 then
                    Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, 1 - (0.5 ^ (1 / (Settings.Smoothness * 60))))
                else
                    Camera.CFrame = targetCFrame
                end
                
                -- Auto shoot
                triggerbot(currentTarget)
            end
        end
    end
end)

-- // ========== CLEANUP ON SCRIPT STOP ==========
game:GetService("Players").LocalPlayer.OnTeleport:Connect(function()
    if screenGui then screenGui:Destroy() end
    if FOVCircle then FOVCircle:Remove() end
