local function Flash(msg)
    Label.Text = msg
    task.wait(2)
    local s = Settings.AimEnabled and "🔴 ON" or "⚫ OFF"
    Label.Text = s .. " | V:Aim T:TP Y:Toggle M:Guns"
end

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.V then
        Settings.AimEnabled = not Settings.AimEnabled
        local s = Settings.AimEnabled and "🔴 ON" or "⚫ OFF"
        Label.Text = s .. " | V:Aim T:TP Y:Toggle M:Guns"
        Label.TextColor3 = Settings.AimEnabled and Color3.fromRGB(255,80,0) or Color3.fromRGB(255,150,50)
    end
    if input.KeyCode == Enum.KeyCode.Y then
        Settings.TeleportEnabled = not Settings.TeleportEnabled
    end
    if input.KeyCode == Enum.KeyCode.T then
        if not Settings.TeleportEnabled then return end
        Flash(TeleportOutside() and "✅ TP Done!" or "❌ TP Failed!")
    end
    if input.KeyCode == Enum.KeyCode.M then
        local c = CollectWeapons()
        Flash(c > 0 and "✅ " .. c .. " guns!" or "❌ None found!")
    end
end)

