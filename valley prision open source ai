local function GetCharacter(Player)
    local Char = Player.Character
    if not Char then return nil end
    local Humanoid = Char:FindFirstChildOfClass("Humanoid")
    local Root = Char:FindFirstChild("HumanoidRootPart")
    if Humanoid and Humanoid.Health > 0 and Root then return Char end
    return nil
end

local function IsEnemy(Player)
    local team = Player.Team
    if not team then return false end
    for _, t in ipairs(EnemyTeams) do
        if team.Name == t then return true end
    end
    return false
end

local function ShouldMiss()
    return math.random(1, 100) <= Settings.MissChance
end

local function IsVisible(Part)
    if not Settings.VisibilityCheck then return true end
    if not Part then return false end
    
    local Origin = Camera.CFrame.Position
    local Direction = (Part.Position - Origin)
    local Distance = Direction.Magnitude
    if Distance > 500 then return false end
    
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.IgnoreWater = true
    
    local ignoreList = {LocalPlayer.Character}
    local cameraParts = Camera:GetChildren()
    for _, v in ipairs(cameraParts) do
        if v:IsA("BasePart") then table.insert(ignoreList, v) end
    end
    params.FilterDescendantsInstances = ignoreList
    
    local Result = Workspace:Raycast(Origin, Direction.Unit * Distance, params)
    if not Result then return true end
    
    local HitInstance = Result.Instance
    local HitModel = HitInstance:FindFirstAncestorWhichIsA("Model")
    return HitModel and (HitModel == Part.Parent or HitModel == Part.Parent.Parent)
end

local function CreateESP(Player)
    if ESPCache[Player] then return end
    local ESP = {}
    pcall(function()
        ESP.BoxOutline = Drawing.new("Square")
        ESP.Box = Drawing.new("Square")
        ESP.Name = Drawing.new("Text")
        ESP.Distance = Drawing.new("Text")
        ESP.HealthBar = Drawing.new("Square")
        ESP.HealthFill = Drawing.new("Square")
        
        ESP.BoxOutline.Thickness = 3; ESP.BoxOutline.Filled = false; ESP.BoxOutline.Color = Color3.new(0,0,0)
        ESP.Box.Thickness = 1; ESP.Box.Filled = false
        ESP.Name.Size = 13; ESP.Name.Center = true; ESP.Name.Outline = true
        ESP.Distance.Size = 12; ESP.Distance.Center = true; ESP.Distance.Outline = true
        ESP.HealthBar.Thickness = 1; ESP.HealthBar.Filled = false; ESP.HealthBar.Color = Color3.new(0,0,0)
        ESP.HealthFill.Thickness = 1; ESP.HealthFill.Filled = true
        
        ESPCache[Player] = ESP
    end)
end

local function RemoveESP(Player)
    local ESP = ESPCache[Player]
    if not ESP then return end
    for _, obj in pairs(ESP) do
        pcall(function() if obj.Remove then obj:Remove() end end)
    end
    ESPCache[Player] = nil
end

local function UpdateESP()
    if not Settings.ESPEnabled then
        for _, ESP in pairs(ESPCache) do
            for _, obj in pairs(ESP) do if obj then obj.Visible = false end end
        end
        return
    end
    
    local toRemove = {}
    for Player, ESP in pairs(ESPCache) do
        if not Players:FindFirstChild(Player.Name) then
            table.insert(toRemove, Player)
        end
    end
    for _, Player in ipairs(toRemove) do
        RemoveESP(Player)
    end
    
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player == LocalPlayer then continue end
        local Character = GetCharacter(Player)
        if not Character then
            RemoveESP(Player)
            continue
        end
        
        CreateESP(Player)
        local ESP = ESPCache[Player]
        if not ESP then continue end
        
        local IsTeam = IsEnemy(Player)
        local Color = IsTeam and Settings.ESPEnemyColor or Settings.ESPFriendColor
        local Head = Character:FindFirstChild("Head")
        local Root = Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        
        if Head and Root and Humanoid then
            local HeadPos, OnScreen = Camera:WorldToViewportPoint(Head.Position)
            if not OnScreen then
                for _, obj in pairs(ESP) do if obj then obj.Visible = false end end
                continue
            end
            
            local BoxHeight = (Head.Position.Y - Root.Position.Y) * 2.2
            local Top = Camera:WorldToViewportPoint(Head.Position + Vector3.new(0, BoxHeight*0.15, 0))
            local Bottom = Camera:WorldToViewportPoint(Root.Position - Vector3.new(0, BoxHeight*0.3, 0))
            local Height = math.abs(Top.Y - Bottom.Y)
            local Width = Height * 0.55
            local BoxPos = Vector2.new(Top.X - Width/2, Top.Y)
            
            if Settings.ESPBoxes and ESP.BoxOutline and ESP.Box then
                ESP.BoxOutline.Size = Vector2.new(Width, Height); ESP.BoxOutline.Position = BoxPos; ESP.BoxOutline.Visible = true
                ESP.Box.Size = Vector2.new(Width, Height); ESP.Box.Position = BoxPos; ESP.Box.Color = Color; ESP.Box.Visible = true
            end
            if Settings.ESPNames and ESP.Name then
                ESP.Name.Text = Player.Name
                ESP.Name.Position = Vector2.new(BoxPos.X + Width/2, BoxPos.Y - 20)
                ESP.Name.Color = Color; ESP.Name.Visible = true
            end
            if Settings.ESPDistance and ESP.Distance then
                local Dist = math.floor((Camera.CFrame.Position - Root.Position).Magnitude)
                ESP.Distance.Text = Dist .. "m"
                ESP.Distance.Position = Vector2.new(BoxPos.X + Width/2, BoxPos.Y + Height + 4)
                ESP.Distance.Color = Color; ESP.Distance.Visible = true
            end
            if Settings.ESPHealth and ESP.HealthBar and ESP.HealthFill then
                local hp = Humanoid.Health / Humanoid.MaxHealth
                local BarX = math.clamp(BoxPos.X - 6, 0, Camera.ViewportSize.X)
                local BarPos = Vector2.new(BarX, BoxPos.Y)
                ESP.HealthBar.Size = Vector2.new(3, Height); ESP.HealthBar.Position = BarPos; ESP.HealthBar.Visible = true
                ESP.HealthFill.Size = Vector2.new(3, Height * hp)
                ESP.HealthFill.Position = Vector2.new(BarPos.X, BarPos.Y + Height*(1-hp))
                ESP.HealthFill.Color = Color3.fromRGB(255*(1-hp), 255*hp, 0)
                ESP.HealthFill.Visible = true
            end
        end
    end
end

local function FindTarget()
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local bestDist = Settings.FOV
    local bestTarget, bestPlayer = nil, nil
    
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player == LocalPlayer then continue end
        local Char = GetCharacter(Player)
        if not Char or not IsEnemy(Player) then continue end
        local Part = Char:FindFirstChild(Settings.AimPart) or Char:FindFirstChild("Head")
        if Part and IsVisible(Part) then
            local sp, onScreen = Camera:WorldToViewportPoint(Part.Position)
            if onScreen then
                local dist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    bestTarget = Part
                    bestPlayer = Player
                end
            end
        end
    end
    
    LockedTarget = bestTarget
    LockedPlayer = bestPlayer
    return bestTarget, bestPlayer
end

local function SmartTeleport(targetPos)
    local Character = LocalPlayer.Character
    if not Character then return false end
    local Root = Character:FindFirstChild("HumanoidRootPart")
    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
    if not Root or not Humanoid then return false end
    
    local dist = (Root.Position - targetPos).Magnitude
    if dist < 0.1 then return true end
    
    if not Settings.AntiRubberband then
        pcall(function() Root.CFrame = CFrame.new(targetPos) end)
        return true
    end
    
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e8, 1e8, 1e8)
    bv.P = 10000
    bv.Parent = Root
    
    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(1e8, 1e8, 1e8)
    bg.P = 10000
    bg.CFrame = Root.CFrame
    bg.Parent = Root
    
    for i = 1, 30 do
        local currentDist = (Root.Position - targetPos).Magnitude
        if currentDist < 3 then break end
        
        local dir = (targetPos - Root.Position)
        if dir.Magnitude > 0.01 then
            bv.Velocity = dir.Unit * math.min(currentDist * 10, 300)
        end
        
        task.wait(0.03)
    end
    
    bv:Destroy()
    bg:Destroy()
    
    return (Root.Position - targetPos).Magnitude < 10
end

local function CollectWeapons()
    local WeaponModels = ReplicatedStorage:FindFirstChild("WeaponModels")
    if not WeaponModels then return 0 end
    
    local Character = LocalPlayer.Character
    if not Character then return 0 end
    local Root = Character:FindFirstChild("HumanoidRootPart")
    if not Root then return 0 end
    
    local originalPos = Root.CFrame
    local count = 0
    
    for _, model in ipairs(WeaponModels:GetChildren()) do
        if model:IsA("Model") then
            local handle = model:FindFirstChild("Handle") or model.PrimaryPart
            if handle and not LastGunGrab[handle] then
                local targetPos = handle.Position + Vector3.new(0, 3, 0)
                local distance = (Root.Position - handle.Position).Magnitude
                if distance < Settings.WeaponGrabRange then
                    if SmartTeleport(targetPos) then
                        LastGunGrab[handle] = tick()
                        task.wait(Settings.WeaponGrabDelay)
                        
                        local proximityPrompt = handle:FindFirstChildOfClass("ProximityPrompt")
                        if proximityPrompt then
                            fireproximityprompt(proximityPrompt)
                            count = count + 1
                        end
                    end
                end
            end
        end
    end
    
    SmartTeleport(originalPos.Position)
    
    for handle, time in pairs(LastGunGrab) do
        if tick() - time > 5 then LastGunGrab[handle] = nil end
    end
    
    return count
end

local function TeleportOutside()
    local Character = LocalPlayer.Character
    if not Character then return false end
    
    local paths = {
        {"Map", "Functional", "Invisible", "EscapeBarriers"},
        {"Map", "Invisible", "EscapeBarriers"},
        {"Map", "EscapeBarriers"}
    }
    
    for _, path in ipairs(paths) do
        local current = Workspace
        for _, name in ipairs(path) do
            current = current:FindFirstChild(name)
            if not current then break end
        end
        if current then
            for _, barrier in ipairs(current:GetChildren()) do
                if barrier:IsA("BasePart") then
                    local tpPos = barrier.Position + Vector3.new(math.random(-5,5), 15, math.random(-5,5))
                    return SmartTeleport(tpPos)
                end
            end
        end
    end
    
    return false
end

local function SetupHooks()
    OldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(Self, ...)
        local Method = getnamecallmethod()
        local Args = {...}
        
        if Method == "FireServer" and Settings.AimEnabled and Settings.SilentAim then
            if tick() - LastHookTime >= 0.05 then
                LastHookTime = tick()
                if Self:IsA("RemoteEvent") then
                    local name = Self.Name:lower()
                    if name:find("shoot") or name:find("fire") or name:find("bullet") or (Self.Parent and Self.Parent:IsA("Tool")) then
                        if not ShouldMiss() and LockedTarget then
                            local TargetPos = LockedTarget.Position
                            for i = 1, #Args do
                                local Arg = Args[i]
                                local argType = typeof(Arg)
                                if argType == "Vector3" then
                                    Args[i] = TargetPos; break
                                elseif argType == "CFrame" then
                                    Args[i] = CFrame.new(TargetPos); break
                                elseif argType == "table" then
                                    if Arg.Position and typeof(Arg.Position) == "Vector3" then
                                        Args[i] = {Position = TargetPos}
                                    elseif Arg.hit and typeof(Arg.hit) == "table" and Arg.hit.Position then
                                        Args[i] = {hit = {Position = TargetPos}}
                                    end
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
        
        return OldNamecall(Self, unpack(Args))
    end))
end

SetupHooks()

RunService.RenderStepped:Connect(function()
    UpdateESP()
    
    local vs = Camera.ViewportSize
    FOVCircle.Position = Vector2.new(vs.X/2, vs.Y/2)
    FOVCircle.Radius = Settings.FOV
    FOVCircle.Visible = Settings.AimEnabled and Settings.FOVVisible
    FOVCircle.Color = Settings.FOVColor
    
    if not Settings.AimEnabled then return end
    
    local Target, _ = FindTarget()
    if not Target then return end
    
    if not Settings.SilentAim then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Position)
    end
    
    if Settings.TriggerBot and Settings.AutoShoot and Target then
        local minDelay = 1 / Settings.TriggerCPS
        local now = tick()
        if now - LastTriggerTime >= minDelay then
            LastTriggerTime = now
            local mp = UserInputService:GetMouseLocation()
            VirtualInputManager:SendMouseButtonEvent(mp.X, mp.Y, 0, 1, nil, 1)
            task.wait(0.008)
            VirtualInputManager:SendMouseButtonEvent(mp.X, mp.Y, 0, 0, nil, 1)
        end
    end
end)

