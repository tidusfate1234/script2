-- Functions
local function GetClosestEnemy()
    local closestEnemy = nil
    local closestDistance = math.huge
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local distance = (Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
            if distance < closestDistance and distance <= AimbotRange then
                closestEnemy = player
                closestDistance = distance
            end
        end
    end
    return closestEnemy
end

local function GetAimbotDirection(enemy)
    local direction = (enemy.Character.HumanoidRootPart.Position - Character.HumanoidRootPart.Position).Unit
    return direction
end

local function PredictBulletTrajectory(startPosition, endPosition, velocity)
    local deltaTime = (endPosition - startPosition).Magnitude / velocity
    local predictedPosition = endPosition + (endPosition - startPosition).Unit * deltaTime * velocity
    return predictedPosition
end

local function Aimbot()
    if AimbotEnabled then
        local closestEnemy = GetClosestEnemy()
        if closestEnemy then
            local direction = GetAimbotDirection(closestEnemy)
            local rotation = math.atan2(direction.X, direction.Z)
            local yaw = math.deg(rotation)
            local pitch = math.deg(math.asin(direction.Y))
            
            -- Apply smoothing
            local smoothedYaw = yaw * AimbotSmoothness / 100
            local smoothedPitch = pitch * AimbotSmoothness / 100
            
            -- Apply prediction
            if AimbotPrediction then
                local predictedPosition = PredictBulletTrajectory(Character.HumanoidRootPart.Position, closestEnemy.Character.HumanoidRootPart.Position, BulletVelocity)
                local predictedDirection = (predictedPosition - Character.HumanoidRootPart.Position).Unit
                local predictedRotation = math.atan2(predictedDirection.X, predictedDirection.Z)
                local predictedYaw = math.deg(predictedRotation)
                local predictedPitch = math.deg(math.asin(predictedDirection.Y))
                smoothedYaw = predictedYaw * AimbotSmoothness / 100
                smoothedPitch = predictedPitch * AimbotSmoothness / 100
            end
            
            Mouse.Rotate = Vector2.new(smoothedYaw, smoothedPitch)
            
            -- Auto-shoot
            if AutoShoot then
                local mouseButton1 = UserInputService:GetMouseButtonsPressed()
                if mouseButton1 then
                    local character = closestEnemy.Character
                    local head = character:FindFirstChild("Head")
                    if head then
                        local raycastParams = RaycastParams.new()
                        raycastParams.FilterDescendantsInstances = {Character}
                        raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
                        local raycastResult = Workspace:Raycast(head.Position, (head.Position - Character.HumanoidRootPart.Position).Unit * 1000, raycastParams)
                        if raycastResult then
                            local humanoid = closestEnemy.Character:FindFirstChild("Humanoid")
                            if humanoid then
                                humanoid:TakeDamage(100)
                            end
                        end
                    end
                end
            end
        end
    end
end

