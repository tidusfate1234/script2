local function GetCharacter(Player)
    local Char = Player.Character
    if not Char then return nil end
    local Humanoid = Char:FindFirstChildOfClass("Humanoid")
    local Root = Char:FindFirstChild("HumanoidRootPart")
    if Humanoid and Humanoid.Health > 0 and Root then
        return Char
    end
    return nil
end

local function HumanizePosition(Position)
    if not Settings.Humanization then return Position end
    local Jitter = Vector3.new(
        (math.random() - 0.5) * Settings.JitterAmount * 2,
        (math.random() - 0.5) * Settings.JitterAmount * 2,
        (math.random() - 0.5) * Settings.JitterAmount * 2
    )
    return Position + Jitter
end

local function GetDynamicPrediction(Part)
    if not Settings.DynamicPrediction then return Settings.Prediction end
    local Velocity = Part.AssemblyLinearVelocity.Magnitude
    if Velocity > 30 then
        return Settings.Prediction * 1.3
    elseif Velocity > 15 then
        return Settings.Prediction * 1.15
    else
        return Settings.Prediction
    end
end

local function GetSmoothedSmoothness(Target)
    if not Settings.AdaptiveSmoothness then return Settings.Smoothness end
    local BaseSmooth = Settings.Smoothness
    if Target then
        local Distance = (Camera.CFrame.Position - Target.Position).Magnitude
        if Distance < 30 then
            BaseSmooth = BaseSmooth * 1.2
        elseif Distance > 100 then
            BaseSmooth = BaseSmooth * 0.9
        end
    end
    return math.clamp(BaseSmooth, 0.05, 1)
end

local function GetAdaptiveFOV(Target)
    if not Settings.AdaptiveFOV then return Settings.FOV end
    if Target then
        local Distance = (Camera.CFrame.Position - Target.Position).Magnitude
        if Distance < 30 then
            return Settings.FOV * 0.7
        elseif Distance < 60 then
            return Settings.FOV * 0.85
        else
            return Settings.FOV
        end
    end
    return Settings.FOV
end

local function ShouldHit()
    if Settings.HitChance >= 100 then return true end
    return math.random(1, 100) <= Settings.HitChance
end

local function ScoreTarget(Player, CrosshairDistance, Distance, Velocity, Health)
    local Score = 
        (CrosshairDistance * Settings.CrosshairWeight) +
        (Distance * Settings.DistanceWeight) +
        (Velocity * Settings.VelocityWeight) +
        ((100 - Health) * Settings.HealthWeight)
    
    if Settings.PrioritySystem == "Health" then
        Score = Score * (1 - (Health / 200))
    elseif Settings.PrioritySystem == "Distance" then
        Score = Score * (1 / (Distance + 1))
    elseif Settings.PrioritySystem == "Damage" and DamageTracker.LastDamager == Player then
        if tick() - DamageTracker.DamageTime < 3 then
            Score = Score * 0.5
        end
    end
    return Score
end

local function IsTeammate(Player)
    if not Settings.TeamCheck then return false end
    if not Player.Team or not LocalPlayer.Team then return false end
    return Player.Team == LocalPlayer.Team
end

local function IsVisible(Part)
    if not Settings.VisibilityCheck then return true end
    if not Part then return false end
    
    local Origin = Camera.CFrame.Position
    local Direction = (Part.Position - Origin)
    local Distance = Direction.Magnitude
    
    if Distance > 500 then return false end
    
    local Char = LocalPlayer.Character
    local FilterList = {}
    
    if Char then
        table.insert(FilterList, Char)
    end
    
    if Part.Parent then
        table.insert(FilterList, Part.Parent)
    end
    
    RaycastParams.FilterDescendantsInstances = FilterList
    
    local Result = Workspace:Raycast(Origin, Direction.Unit * (Distance - 0.1), RaycastParams)
    
    if not Result then
        return true
    end
    
    local HitInstance = Result.Instance
    local HitModel = HitInstance:FindFirstAncestorWhichIsA("Model")
    
    if HitModel == Part.Parent or HitInstance:IsDescendantOf(Part.Parent) then
        return true
    end
    
    return false
end

local function GetPredictedPosition(Part, Velocity)
    if not Part then return nil end
    
    local Vel = Velocity or Part.AssemblyLinearVelocity or Vector3.zero
    
    Vel = Vector3.new(
        math.clamp(Vel.X, -Settings.VelocityClamp, Settings.VelocityClamp),
        math.clamp(Vel.Y, -Settings.VelocityClamp, Settings.VelocityClamp),
        math.clamp(Vel.Z, -Settings.VelocityClamp, Settings.VelocityClamp)
    )
    
    local PredictionAmount = GetDynamicPrediction(Part)
    local PredictedPos = Part.Position + (Vel * PredictionAmount * Settings.PredictionMultiplier)
    
    return HumanizePosition(PredictedPos)
end

local function IsTargetUnderCrosshair(Target)
    if not Target then return false end
    
    local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Target.Position)
    if not OnScreen then return false end
    
    local ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local Distance = (Vector2.new(ScreenPos.X, ScreenPos.Y) - ScreenCenter).Magnitude
    
    return Distance < 50
end

local function ScanTargets()
    local CurrentTime = tick()
    
    if CurrentTime - LastScanTime < Settings.ScanInterval then return end
    LastScanTime = CurrentTime
    
    local BestPart = nil
    local BestPlayer = nil
    local BestVelocity = nil
    local BestScore = math.huge
    
    local CameraPos = Camera.CFrame.Position
    local ViewportSize = Camera.ViewportSize
    local ScreenCenter = Vector2.new(ViewportSize.X / 2, ViewportSize.Y / 2)
    
    local CurrentFOV = GetAdaptiveFOV(ScanCache.BestTarget)
    
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            local Character = GetCharacter(Player)
            if Character and not IsTeammate(Player) then
                local AimPart = Character:FindFirstChild(Settings.AimPart) or Character:FindFirstChild("HumanoidRootPart")
                
                if AimPart and IsVisible(AimPart) then
                    local ScreenPos, OnScreen = Camera:WorldToViewportPoint(AimPart.Position)
                    
                    if OnScreen then
                        local CrosshairDistance = (Vector2.new(ScreenPos.X, ScreenPos.Y) - ScreenCenter).Magnitude
                        
                        if CrosshairDistance < CurrentFOV then
                            if Settings.SmartTargeting then
                                local Distance = (CameraPos - AimPart.Position).Magnitude
                                local Velocity = AimPart.AssemblyLinearVelocity.Magnitude
                                local Health = 100
                                local Humanoid = Character:FindFirstChildOfClass("Humanoid")
                                if Humanoid then
                                    Health = Humanoid.Health
                                end
                                
                                local Score = ScoreTarget(Player, CrosshairDistance, Distance, Velocity, Health)
                                if Score < BestScore then
                                    BestScore = Score
                                    BestPart = AimPart
                                    BestPlayer = Player
                                    BestVelocity = AimPart.AssemblyLinearVelocity
                                end
                            else
                                if CrosshairDistance < BestScore then
                                    BestScore = CrosshairDistance
                                    BestPart = AimPart
                                    BestPlayer = Player
                                    BestVelocity = AimPart.AssemblyLinearVelocity
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    
    ScanCache.BestTarget = BestPart
    ScanCache.BestPlayer = BestPlayer
    ScanCache.BestVelocity = BestVelocity
    ScanCache.BestPosition = BestPart and GetPredictedPosition(BestPart, BestVelocity) or nil
    
    if BestPart and BestPlayer then
        TargetLock.Player = BestPlayer
        TargetLock.Part = BestPart
        TargetLock.Velocity = BestVelocity
        TargetLock.Position = ScanCache.BestPosition
    else
        TargetLock.Player = nil
        TargetLock.Part = nil
        TargetLock.Velocity = nil
        TargetLock.Position = nil
    end
end

local function GetBestTarget()
    local CurrentTime = tick()
    
    if Settings.StickyAim and TargetLock.Player and TargetLock.Part then
        local LockChar = GetCharacter(TargetLock.Player)
        if LockChar and not IsTeammate(TargetLock.Player) then
            local LockPart = LockChar:FindFirstChild(Settings.AimPart) or LockChar:FindFirstChild("HumanoidRootPart")
            
            if LockPart and IsVisible(LockPart) then
                local ScreenPos, OnScreen = Camera:WorldToViewportPoint(LockPart.Position)
                if OnScreen then
                    local ScreenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
                    local Distance = (Vector2.new(ScreenPos.X, ScreenPos.Y) - ScreenCenter).Magnitude
                    local CurrentFOV = GetAdaptiveFOV(LockPart)
                    if Distance < CurrentFOV then
                        TargetLock.Part = LockPart
                        TargetLock.Velocity = LockPart.AssemblyLinearVelocity
                        TargetLock.Position = GetPredictedPosition(LockPart, TargetLock.Velocity)
                        return LockPart, TargetLock.Player, TargetLock.Velocity, TargetLock.Position
                    end
                end
            end
        end
        TargetLock.Player = nil
        TargetLock.Part = nil
        TargetLock.Velocity = nil
        TargetLock.Position = nil
    end
    
    if CurrentTime - LastTargetRefresh < TargetRefreshDelay then
        return ScanCache.BestTarget, ScanCache.BestPlayer, ScanCache.BestVelocity, ScanCache.BestPosition
    end
    
    LastTargetRefresh = CurrentTime
    ScanTargets()
    return ScanCache.BestTarget, ScanCache.BestPlayer, ScanCache.BestVelocity, ScanCache.BestPosition
end

local function TriggerBotCheck()
    if not (Settings.TriggerBot and Settings.Enabled) then return end
    if not ShouldHit() then return end
    
    local CurrentTime = tick()
    if CurrentTime - LastTriggerTime < Settings.TriggerDelay then return end
    
    local Character = GetCharacter(LocalPlayer)
    if not Character then return end
    
    local Target, _, _, TargetPos = GetBestTarget()
    if not Target then return end
    
    if Settings.TriggerRequiresOnTarget and not IsTargetUnderCrosshair(Target) then
        return
    end
    
    if Settings.AutoShoot then
        LastTriggerTime = CurrentTime
        local MousePos = UserInputService:GetMouseLocation()
        VirtualInputManager:SendMouseButtonEvent(MousePos.X, MousePos.Y, 0, true, game, 1)
        task.wait(0.016)
        VirtualInputManager:SendMouseButtonEvent(MousePos.X, MousePos.Y, 0, false, game, 1)
    end
end

local function SetupSilentAim()
    for _, conn in ipairs(SilentAimConnections) do
        pcall(function() conn:Disconnect() end)
    end
    SilentAimConnections = {}
    
    if OldNamecall and OriginalNamecall then
        pcall(function()
            hookmetamethod(game, "__namecall", OriginalNamecall)
        end)
        OldNamecall = nil
        OriginalNamecall = nil
    end
    
    OriginalNamecall = getrawmetatable(game).__namecall
    
    local Success, Err = pcall(function()
        OldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(Self, ...)
            local Method = getnamecallmethod()
            local Args = {...}
            
            if Method == "FireServer" and Settings.Enabled and Settings.SilentAim and ShouldHit() then
                if Self:IsA("RemoteEvent") then
                    local RemoteName = tostring(Self):lower()
                    if RemoteName:find("shoot") or RemoteName:find("hit") or RemoteName:find("bullet") or RemoteName:find("fire") then
                        local Target, _, _, TargetPos = GetBestTarget()
                        if Target and IsVisible(Target) then
                            for i, Arg in pairs(Args) do
                                if typeof(Arg) == "Vector3" then
                                    Args[i] = TargetPos
                                    break
                                elseif typeof(Arg) == "CFrame" then
                                    Args[i] = CFrame.new(TargetPos)
                                    break
                                elseif typeof(Arg) == "table" then
                                    if Arg.Position and typeof(Arg.Position) == "Vector3" then
                                        Arg.Position = TargetPos
                                        break
                                    elseif Arg.hit and Arg.hit.Position and typeof(Arg.hit.Position) == "Vector3" then
                                        Arg.hit.Position = TargetPos
                                        break
                                    end
                                end
                            end
                        end
                    end
                end
            end
            
            return OldNamecall(Self, unpack(Args))
        end))
    end)
end

SetupSilentAim()

HeartbeatConnection = RunService.Heartbeat:Connect(function()
