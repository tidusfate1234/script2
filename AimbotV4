RenderConnection = RunService.RenderStepped:Connect(function()
    if not Settings.Enabled then
        if FOVCircle then FOVCircle.Visible = false end
        return
    end
    
    local CurrentTarget = ScanCache.BestTarget
    local CurrentFOV = GetAdaptiveFOV(CurrentTarget)
    local ViewportSize = Camera.ViewportSize
    
    if FOVCircle and type(FOVCircle) == "table" and FOVCircle.Position then
        FOVCircle.Position = Vector2.new(ViewportSize.X / 2, ViewportSize.Y / 2)
        FOVCircle.Radius = CurrentFOV
        FOVCircle.Visible = Settings.ShowFOV
        FOVCircle.Color = Settings.FOVColor
    end

    if not Settings.SilentAim and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        if ShouldHit() then
            local Target, _, _, TargetPos = GetBestTarget()
            if Target and IsVisible(Target) then
                local TargetCFrame = CFrame.new(Camera.CFrame.Position, TargetPos)
                local Smoothness = GetSmoothedSmoothness(Target)
                if Smoothness >= 1 then
                    Camera.CFrame = TargetCFrame
                else
                    Camera.CFrame = Camera.CFrame:Lerp(TargetCFrame, Smoothness)
                end
            end
        end
    end

    TriggerBotCheck()
end)

local function SetupDamageTracker()
    if DamageConnection then
        DamageConnection:Disconnect()
    end
    
    DamageConnection = LocalPlayer.CharacterAdded:Connect(function(Char)
        local Humanoid = Char:WaitForChild("Humanoid")
        
        local LastHealth = Humanoid.Health
        
        Humanoid.HealthChanged:Connect(function(NewHealth)
            if NewHealth < LastHealth then
                local Attacker = nil
                local PlayersList = Players:GetPlayers()
                for _, Player in ipairs(PlayersList) do
                    if Player ~= LocalPlayer then
                        local PlayerChar = Player.Character
                        if PlayerChar then
                            local PlayerRoot = PlayerChar:FindFirstChild("HumanoidRootPart")
                            if PlayerRoot and (PlayerRoot.Position - Char.HumanoidRootPart.Position).Magnitude < 15 then
                                Attacker = PlayerChar
                                break
                            end
                        end
                    end
                end
                
                if Attacker then
                    local AttackingPlayer = Players:GetPlayerFromCharacter(Attacker)
                    if AttackingPlayer then
                        DamageTracker.LastDamager = AttackingPlayer
                        DamageTracker.DamageTime = tick()
                    end
                end
            end
            LastHealth = NewHealth
        end)
    end)
end

SetupDamageTracker()

