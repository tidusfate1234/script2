local PlayerButtons = {}

local function refreshPlayerList()
    for _, btn in ipairs(PlayerButtons) do
        btn:Destroy()
    end
    PlayerButtons = {}
    
    local yPos = 0
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -10, 0, 28)
            btn.Position = UDim2.new(0, 5, 0, yPos)
            btn.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
            btn.Text = player.Name
            btn.TextColor3 = Colors.Light
            btn.TextSize = 13
            btn.Font = Enum.Font.Gotham
            btn.Parent = PlayerList
            
            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 6)
            btnCorner.Parent = btn
            
            btn.MouseButton1Click:Connect(function()
                if player.Character then
                    Settings.Target = player.Character:FindFirstChild("HumanoidRootPart")
                    if Settings.Target then
                        TargetLabel.Text = "🎯 Target: " .. player.Name .. " (HRP)"
                        TargetLabel.TextColor3 = Colors.Success
                    end
                end
            end)
            
            table.insert(PlayerButtons, btn)
            yPos = yPos + 32
        end
    end
    PlayerList.CanvasSize = UDim2.new(0, 0, 0, yPos + 5)
end

