-- Click detection
local Mouse = LocalPlayer:GetMouse()
Mouse.Button1Down:Connect(function()
    if selectionMode == "seat" then
        if Mouse.Target then
            Settings.Seat = Mouse.Target
            SeatLabel.Text = "🪑 Seat: " .. Mouse.Target.Name
            SeatLabel.TextColor3 = Colors.Success
            selectionMode = nil
            SelectSeatButton.Text = "Click to Select Seat"
            SelectSeatButton.BackgroundColor3 = Colors.Secondary
        end
    elseif selectionMode == "target" then
        if Mouse.Target then
            Settings.Target = Mouse.Target
            TargetLabel.Text = "🎯 Target: " .. Mouse.Target.Name
            TargetLabel.TextColor3 = Colors.Success
            selectionMode = nil
            SelectTargetButton.Text = "Click to Select Target"
            SelectTargetButton.BackgroundColor3 = Colors.Secondary
        end
    end
end)

-- Slider dragging
local dragging = false
PowerSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
    end
end)

PowerSlider.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mousePos = UserInputService:GetMouseLocation()
        local sliderPos = PowerSlider.AbsolutePosition
        local sliderSize = PowerSlider.AbsoluteSize
        
        local percent = math.clamp((mousePos.X - sliderPos.X) / sliderSize.X, 0, 1)
        local value = math.floor(percent * 20e9)
        Settings.VelocityPower = value
        PowerFill.Size = UDim2.new(percent, 0, 1, 0)
        PowerLabel.Text = "⚡ Velocity Power: " .. value
    end
end)

-- Toggle Fling
ToggleButton.MouseButton1Click:Connect(function()
    if not Settings.Seat then
        ToggleButton.Text = "❌ SELECT A SEAT!"
        task.wait(1)
        ToggleButton.Text = Settings.Enabled and "⏹ STOP FLING" or "▶ START FLING"
        return
    end
    
    if not Settings.Target then
        ToggleButton.Text = "❌ SELECT A TARGET!"
        task.wait(1)
        ToggleButton.Text = Settings.Enabled and "⏹ STOP FLING" or "▶ START FLING"
        return
    end
    
    Settings.Enabled = not Settings.Enabled
    
    if Settings.Enabled then
        ToggleButton.Text = "⏹ STOP FLING"
        ToggleButton.BackgroundColor3 = Colors.Danger
        
        if Velocity then Velocity:Destroy() end
        
        Velocity = Instance.new("BodyVelocity")
        Velocity.P = 1e6
        Velocity.MaxForce = Vector3.one * 1e6
        Velocity.Velocity = Vector3.one * Settings.VelocityPower
        Velocity.Parent = Settings.Seat
        
        if Connection then Connection:Disconnect() end
        Connection = RunService.Heartbeat:Connect(function()
            if Settings.Seat and Settings.Target and Settings.Seat.Parent and Settings.Target.Parent then
                Settings.Seat.Velocity = Vector3.one * Settings.CFramePower
                Settings.Seat.CFrame = Settings.Target.CFrame
            else
                Settings.Enabled = false
                ToggleButton.Text = "▶ START FLING"
                ToggleButton.BackgroundColor3 = Colors.Success
                if Velocity then Velocity:Destroy() end
                if Connection then Connection:Disconnect() end
            end
        end)
    else
        ToggleButton.Text = "▶ START FLING"
        ToggleButton.BackgroundColor3 = Colors.Success
        if Velocity then Velocity:Destroy() end
        if Connection then Connection:Disconnect() end
    end
end)

-- GUI Dragging
local guiDragging = false
local dragStart = nil
local startPos = nil

TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        guiDragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
    end
end)

TitleBar.InputChanged:Connect(function(input)
    if guiDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

TitleBar.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        guiDragging = false
    end
end)

