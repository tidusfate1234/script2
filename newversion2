local function SetupSlider(sliderFrame, fill, label, minVal, maxVal, callback)
sliderFrame.InputBegan:Connect(function(input)
if input.UserInputType == Enum.UserInputType.MouseButton1 then
local relativeX = math.clamp((input.Position.X - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
local value = math.floor(minVal + (maxVal - minVal) * relativeX + 0.5)
fill.Size = UDim2.new(relativeX, 0, 1, 0)
label.Text = label.Text:gsub("%d+", value):match("(.+): %d+") .. ": " .. value
callback(value)
end
end)
end
