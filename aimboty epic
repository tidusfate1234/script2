-- Safe Character Getter
local function GetCharacter(Player)
    local Char = Player.Character
    if not Char then return nil end
    
    local Humanoid = Char:FindFirstChildOfClass("Humanoid")
    local Root = Char:FindFirstChild("HumanoidRootPart")
    
    if Humanoid and Humanoid.Health > 0 and Root then
        return Char
    end
    
    return nil
end

-- Improved Prediction (Fixed over-prediction issue)
local function GetPredictedPosition(TargetPart, UseSimplePrediction)
    if not TargetPart then return TargetPart.Position end
    
    local Character = TargetPart.Parent
    if not Character then return TargetPart.Position end
    
    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
    local RootPart = Character:FindFirstChild("HumanoidRootPart")
    
    if not Humanoid or not RootPart then return TargetPart.Position end
    
    -- Get velocity with fallback
    local Velocity = RootPart.AssemblyLinearVelocity or Vector3.zero
    local TargetPosition = TargetPart.Position
    
    -- Store for smoothing
    if TargetLock.Part == TargetPart then
        if TargetLock.LastVelocity then
            -- Smooth velocity to prevent jitter
            Velocity = Velocity:Lerp(TargetLock.LastVelocity, 0.7)
        end
        TargetLock.LastVelocity = Velocity
        TargetLock.LastPosition = TargetPosition
    end
    
    -- Check if target is moving significantly
    local Speed = Velocity.Magnitude
    local PredictionTime = Settings.Prediction
    
    -- Adjust prediction based on distance
    local Distance = (Camera.CFrame.Position - TargetPosition).Magnitude
    local DistanceMultiplier = math.clamp(Distance / 100, 0.5, 1.5)
    
    -- Reduce prediction for close targets to prevent overshooting
    if Distance < 50 then
        PredictionTime = PredictionTime * 0.5
    end
    
    -- Dynamic prediction based on movement state
    if Humanoid.MoveDirection.Magnitude > 0 then
        -- Moving - use full prediction
        PredictionTime = PredictionTime * DistanceMultiplier
    elseif Speed > 2 then
        -- Falling or knockback - reduced prediction
        PredictionTime = PredictionTime * 0.6
    else
        -- Standing still - minimal prediction
        PredictionTime = PredictionTime * 0.2
    end
    
    -- Apply prediction with limits
    local PredictedPosition = TargetPosition + (Velocity * PredictionTime)
    
    -- Clamp prediction to prevent extreme values
    local MaxPredictionDistance = 25
    local PredictionOffset = (PredictedPosition - TargetPosition).Magnitude
    if PredictionOffset > MaxPredictionDistance then
        PredictedPosition = TargetPosition + (Velocity.Unit * MaxPredictionDistance)
    end
    
    return PredictedPosition
end

-- Check if target is visible
local function IsVisible(Part)
    if not Settings.VisibilityCheck then return true end
    if not Part then return false end
    
    local Origin = Camera.CFrame.Position
    local Direction = (Part.Position - Origin)
    local Distance = Direction.Magnitude
    
    if Distance > 500 then return false end
    
    local Char = LocalPlayer.Character
    if Char then
        RaycastParams.FilterDescendantsInstances = {Char}
    end
    
    local Result = Workspace:Raycast(Origin, Direction.Unit * Distance, RaycastParams)
    
    if not Result then return true end
    
    local HitInstance = Result.Instance
    local HitModel = HitInstance:FindFirstAncestorWhichIsA("Model")
    
    return HitModel == Part.Parent or HitInstance:IsDescendantOf(Part.Parent)
end

-- Check if player is teammate
local function IsTeammate(Player)
    if not Settings.TeamCheck then return false end
    if not Player.Team or not LocalPlayer.Team then return false end
    return Player.Team == LocalPlayer.Team
end

-- ESP Functions
local function CreateESP(Player)
    if ESPCache[Player] then return end
    
    local ESP = {
        Box = Drawing.new("Square"),
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        HealthBar = Drawing.new("Square"),
        HealthFill = Drawing.new("Square"),
        HeadDot = Drawing.new("Circle"),
        Tracer = Drawing.new("Line")
    }
    
    -- Configure ESP elements
    ESP.Box.Thickness = 2
    ESP.Box.Filled = false
    ESP.Box.Visible = false
    
    ESP.Name.Size = 13
    ESP.Name.Center = true
    ESP.Name.Outline = true
    ESP.Name.Visible = false
    
    ESP.Distance.Size = 12
    ESP.Distance.Center = true
    ESP.Distance.Outline = true
    ESP.Distance.Visible = false
    
    ESP.HealthBar.Thickness = 1
    ESP.HealthBar.Filled = false
    ESP.HealthBar.Visible = false
    
    ESP.HealthFill.Thickness = 1
    ESP.HealthFill.Filled = true
    ESP.HealthFill.Visible = false
    
    ESP.HeadDot.Radius = 5
    ESP.HeadDot.Filled = true
    ESP.HeadDot.Visible = false
    
    ESP.Tracer.Thickness = 1
    ESP.Tracer.Visible = false
    
    ESPCache[Player] = ESP
end

local function RemoveESP(Player)
    local ESP = ESPCache[Player]
    if ESP then
        for _, drawing in pairs(ESP) do
            pcall(function() drawing:Remove() end)
        end
        ESPCache[Player] = nil
    end
end

local function UpdateESP()
    if not Settings.ESPEnabled then
        for _, ESP in pairs(ESPCache) do
            ESP.Box.Visible = false
            ESP.Name.Visible = false
            ESP.Distance.Visible = false
            ESP.HealthBar.Visible = false
            ESP.HealthFill.Visible = false
            ESP.HeadDot.Visible = false
            ESP.Tracer.Visible = false
        end
        return
    end
    
    local CurrentTime = tick()
    if CurrentTime - LastESPUpdate < 0.033 then return end
    LastESPUpdate = CurrentTime
    
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            local Character = GetCharacter(Player)
            if Character then
                CreateESP(Player)
                local ESP = ESPCache[Player]
                if not ESP then continue end
                
                local IsTeam = IsTeammate(Player)
                local Color = IsTeam and Settings.ESPTeamColor or Settings.ESPColor
                local Head = Character:FindFirstChild("Head")
                local Root = Character:FindFirstChild("HumanoidRootPart")
                local Humanoid = Character:FindFirstChildOfClass("Humanoid")
                
                if Head and Root and Humanoid then
                    local HeadPos, HeadOnScreen = Camera:WorldToViewportPoint(Head.Position)
                    local RootPos, RootOnScreen = Camera:WorldToViewportPoint(Root.Position)
                    
                    if HeadOnScreen or RootOnScreen then
                        -- Calculate box
                        local BoxHeight = (Head.Position - Root.Position).Magnitude * 1.5
                        local BoxWidth = BoxHeight * 0.5
                        local BoxTop = Head.Position + Vector3.new(0, BoxHeight * 0.2, 0)
                        local BoxBottom = Root.Position - Vector3.new(0, BoxHeight * 0.3, 0)
                        
                        local TopPos = Camera:WorldToViewportPoint(BoxTop)
                        local BottomPos = Camera:WorldToViewportPoint(BoxBottom)
                        
                        if TopPos and BottomPos then
                            local BoxSize = Vector2.new((BottomPos.X - TopPos.X) * 0.5, TopPos.Y - BottomPos.Y)
                            local BoxPosition = Vector2.new(TopPos.X - BoxSize.X * 0.5, TopPos.Y)
                            
                            -- Box
                            if Settings.ESPBoxes then
                                ESP.Box.Size = BoxSize
                                ESP.Box.Position = BoxPosition
                                ESP.Box.Color = Color
                                ESP.Box.Visible = true
                            else
                                ESP.Box.Visible = false
                            end
                            
                            -- Name
                            if Settings.ESPNames then
                                ESP.Name.Text = Player.Name
                                ESP.Name.Position = Vector2.new(BoxPosition.X + BoxSize.X * 0.5, BoxPosition.Y - 20)
                                ESP.Name.Color = Color
                                ESP.Name.Visible = true
                            else
                                ESP.Name.Visible = false
                            end
                            
                            -- Distance
                            if Settings.ESPDistance then
                                local Distance = math.floor((Camera.CFrame.Position - Root.Position).Magnitude)
                                ESP.Distance.Text = Distance .. "m"
                                ESP.Distance.Position = Vector2.new(BoxPosition.X + BoxSize.X * 0.5, BoxPosition.Y + BoxSize.Y + 5)
                                ESP.Distance.Color = Color
                                ESP.Distance.Visible = true
                            else
                                ESP.Distance.Visible = false
                            end
                            
                            -- Health
                            if Settings.ESPHealth and Humanoid then
                                local HealthPercent = Humanoid.Health / Humanoid.MaxHealth
                                local BarHeight = BoxSize.Y
                                local BarWidth = 3
                                local BarPos = Vector2.new(BoxPosition.X - BarWidth - 2, BoxPosition.Y)
                                
                                ESP.HealthBar.Size = Vector2.new(BarWidth, BarHeight)
                                ESP.HealthBar.Position = BarPos
                                ESP.HealthBar.Color = Color3.fromRGB(0, 0, 0)
                                ESP.HealthBar.Visible = true
                                
                                ESP.HealthFill.Size = Vector2.new(BarWidth, BarHeight * HealthPercent)
                                ESP.HealthFill.Position = Vector2.new(BarPos.X, BarPos.Y + BarHeight * (1 - HealthPercent))
                                ESP.HealthFill.Color = Color3.fromRGB(255 * (1 - HealthPercent), 255 * HealthPercent, 0)
                                ESP.HealthFill.Visible = true
                            else
                                ESP.HealthBar.Visible = false
                                ESP.HealthFill.Visible = false
                            end
                            
                            -- Head Dot
                            if Settings.ESPHeadDot then
                                ESP.HeadDot.Position = Vector2.new(HeadPos.X, HeadPos.Y)
                                ESP.HeadDot.Color = Color3.fromRGB(255, 255, 255)
                                ESP.HeadDot.Visible = true
                            else
                                ESP.HeadDot.Visible = false
                            end
                            
                            -- Tracer
                            if Settings.ESPTracers then
                                local ViewportSize = Camera.ViewportSize
                                ESP.Tracer.From = Vector2.new(ViewportSize.X / 2, ViewportSize.Y)
                                ESP.Tracer.To = Vector2.new(BottomPos.X, BottomPos.Y)
                                ESP.Tracer.Color = Color
                                ESP.Tracer.Visible = true
                            else
                                ESP.Tracer.Visible = false
                            end
                        end
                    else
                        ESP.Box.Visible = false
                        ESP.Name.Visible = false
                        ESP.Distance.Visible = false
                        ESP.HealthBar.Visible = false
                        ESP.HealthFill.Visible = false
                        ESP.HeadDot.Visible = false
                        ESP.Tracer.Visible = false
                    end
                end
            else
                RemoveESP(Player)
            end
        end
    end
end

-- Target Scanning
local function ScanTargets()
    local CurrentTime = tick()
    
    if CurrentTime - LastScanTime < 0.01 then return end
    LastScanTime = CurrentTime
    
    local BestPart = nil
    local BestPlayer = nil
    local BestScore = math.huge
    
    local CameraPos = Camera.CFrame.Position
    local ViewportSize = Camera.ViewportSize
    local ScreenCenter = Vector2.new(ViewportSize.X / 2, ViewportSize.Y / 2)
    
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            local Character = GetCharacter(Player)
            if Character and not IsTeammate(Player) then
                local AimPart = Character:FindFirstChild(Settings.AimPart) or Character:FindFirstChild("Head") or Character:FindFirstChild("HumanoidRootPart")
                
                if AimPart and IsVisible(AimPart) then
                    local ScreenPos, OnScreen = Camera:WorldToViewportPoint(AimPart.Position)
                    
                    if OnScreen then
                        local CrosshairDistance = (Vector2.new(ScreenPos.X, ScreenPos.Y) - ScreenCenter).Magnitude
                        
                        if CrosshairDistance < Settings.FOV then
                            local Score = CrosshairDistance
                            local Distance = (CameraPos - AimPart.Position).Magnitude
                            
                            -- Prioritize closer targets
                            Score = Score * 0.6 + Distance * 0.4
                            
                            if Score < BestScore then
                                BestScore = Score
                                BestPart = AimPart
                                BestPlayer = Player
                            end
                        end
                    end
                end
            end
        end
    end
    
    if BestPart and BestPlayer then
        if TargetLock.Player ~= BestPlayer then
            TargetLock.Player = BestPlayer
            TargetLock.Part = BestPart
            TargetLock.LastPosition = BestPart.Position
            TargetLock.LastVelocity = Vector3.zero
        else
            TargetLock.Part = BestPart
        end
        ScanCache.BestTarget = BestPart
        ScanCache.BestPlayer = BestPlayer
        ScanCache.BestScore = BestScore
    else
        TargetLock.Player = nil
        TargetLock.Part = nil
        TargetLock.LastVelocity = nil
        ScanCache.BestTarget = nil
        ScanCache.BestPlayer = nil
        ScanCache.BestScore = math.huge
    end
end

local function GetBestTarget()
    return ScanCache.BestTarget, ScanCache.BestPlayer
end

-- Silent Aim Hook (Fixed)
local function SetupSilentAim()
    if SilentAimHooked then
        -- Unhook first
        if OldNamecall then
            pcall(function()
                hookmetamethod(game, "__namecall", OldNamecall)
            end)
        end
        SilentAimHooked = false
    end
    
    OldNamecall = hookmetamethod(game, "__namecall", function(Self, ...)
        local Method = getnamecallmethod()
        local Args = {...}
        
        if Method == "FireServer" and Settings.Enabled and Settings.SilentAim then
            if Self:IsA("RemoteEvent") then
                local Target = ScanCache.BestTarget
                if Target then
                    local PredictedPos = GetPredictedPosition(Target)
                    
                    -- Modify the arguments based on what we find
                    for i, Arg in pairs(Args) do
                        if typeof(Arg) == "Vector3" then
                            Args[i] = PredictedPos
                            break
                        elseif typeof(Arg) == "CFrame" then
                            Args[i] = CFrame.new(PredictedPos)
                            break
                        elseif typeof(Arg) == "table" then
                            if Arg.hit and Arg.hit.Position then
                                Arg.hit.Position = PredictedPos
                                break
                            elseif Arg.Position then
                                Arg.Position = PredictedPos
                                break
                            end
                        end
                    end
                end
            end
        end
        
        return OldNamecall(Self, unpack(Args))
    end)
    
    SilentAimHooked = true
    print("✅ Silent Aim Hooked")
end

-- Trigger Bot
local function TriggerBotCheck()
    if not (Settings.TriggerBot and Settings.Enabled) then return end
    
    local CurrentTime = tick()
    if CurrentTime - LastTriggerTime < Settings.TriggerDelay then return end
    
    local Target, _ = GetBestTarget()
    if not Target then return end
    
    -- Check if crosshair is on target
    local ScreenPos, OnScreen = Camera:WorldToViewportPoint(Target.Position)
    if not OnScreen then return end
    
    local ViewportSize = Camera.ViewportSize
    local ScreenCenter = Vector2.new(ViewportSize.X / 2, ViewportSize.Y / 2)
    local Distance = (Vector2.new(ScreenPos.X, ScreenPos.Y) - ScreenCenter).Magnitude
    
    -- Only trigger if within 50 pixels of target
    if Distance < 50 then
        LastTriggerTime = CurrentTime
        if Settings.AutoShoot then
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
            task.wait(0.05)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
        end
    end
end

-- Smooth Camera Lock (Fixed jitter)
local function SmoothCameraLock()
    local Target, _ = GetBestTarget()
    if not Target then return end
    
    local TargetPos = GetPredictedPosition(Target)
    local CameraPos = Camera.CFrame.Position
    
    -- Calculate target direction
    local TargetDirection = (TargetPos - CameraPos).Unit
    local CurrentDirection = Camera.CFrame.LookVector
    
    -- Smooth interpolation
    local SmoothFactor = math.clamp(Settings.Smoothness * 2, 0.05, 0.3)
    local NewDirection = CurrentDirection:Lerp(TargetDirection, SmoothFactor).Unit
    
    -- Apply new camera rotation
    Camera.CFrame = CFrame.new(CameraPos, CameraPos + NewDirection)
end

-- Player tracking for ESP
local function SetupPlayerTracking()
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player ~= LocalPlayer then
            CreateESP(Player)
        end
    end
    
    table.insert(ESPConnections, Players.PlayerAdded:Connect(function(Player)
        CreateESP(Player)
    end))
    
    table.insert(ESPConnections, Players.PlayerRemoving:Connect(function(Player)
        RemoveESP(Player)
    end))
end

