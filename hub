if Tab3 then Tab3.Text = GameConfig.Tab3; TabObjects[3] = Tab3 end
if Tab4 and GameConfig.Tab4 then Tab4.Text = GameConfig.Tab4; Tab4.Visible = true; TabObjects[4] = Tab4 elseif Tab4 then Tab4.Visible = false end
if Tab5 and GameConfig.Tab5 then Tab5.Text = GameConfig.Tab5; Tab5.Visible = true; TabObjects[5] = Tab5 elseif Tab5 then Tab5.Visible = false end

local Buttons = {}
for i = 1, 15 do
    local btn = ScreenGui:FindFirstChild("Button" .. i)
    if btn and (btn:IsA("TextButton") or btn:IsA("ImageButton")) then
        Buttons[i] = btn
        btn.Visible = false
    end
end

local currentTab = 1

local function HideAllButtons()
    for _, btn in pairs(Buttons) do
        btn.Visible = false
    end
end

local function ShowTabButtons(tabNum)
    HideAllButtons()
    local startIndex = (tabNum - 1) * 15 + 1
    local endIndex = startIndex + 14
    for i = startIndex, endIndex do
        if Buttons[i] then
            Buttons[i].Visible = true
        end
    end
end

local function SwitchTab(tabNum)
    if tabNum == currentTab then return end
    currentTab = tabNum
    for i, tab in pairs(TabObjects) do
        if tab then
            tab.BackgroundColor3 = (i == tabNum) and GameConfig.Color or Color3.fromRGB(45, 45, 45)
        end
    end
    ShowTabButtons(tabNum)
end

for i, tab in pairs(TabObjects) do
    if tab then
        tab.MouseButton1Click:Connect(function()
            SwitchTab(i)
        end)
    end
end

local function AutoScale()
    local viewport = workspace.CurrentCamera.ViewportSize
    local scale = math.min(viewport.X / 1920, viewport.Y / 1080)
    local minScale = 0.5
    for _, obj in ipairs(ScreenGui:GetDescendants()) do
        if obj:IsA("UIScale") then
            obj.Scale = math.max(scale, minScale)
        end
    end
end

local function PlayIntro()
    DropDownForStartingFrame.Position = UDim2.new(0.5, 0, -0.2, 0)
    DropDownForStartingFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    DropDownForStartingFrame.Size = UDim2.new(0, 353, 0, 20)
    DropDownForStartingFrame.BackgroundTransparency = 1
    DropDownForStartingFrame.Visible = true

    local fadeIn = TweenService:Create(DropDownForStartingFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 0})
    fadeIn:Play()
    fadeIn.Completed:Wait()
    task.wait(0.3)

    StartingFrame.Position = UDim2.new(0.5, 0, -0.3, 0)
    StartingFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    StartingFrame.Size = UDim2.new(0, 312, 0, 241)
    StartingFrame.Visible = true

    local slideDown = TweenService:Create(StartingFrame, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0.333, 0, 0.27, 0)})
    slideDown:Play()
    slideDown.Completed:Wait()
    task.wait(0.4)

    local spin360 = TweenService:Create(StartingFrame, TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut), {Rotation = 360})
    spin360:Play()
    spin360.Completed:Wait()
    StartingFrame.Rotation = 0

    local shrink = TweenService:Create(StartingFrame, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
    shrink:Play()
    shrink.Completed:Wait()
    StartingFrame.Visible = false

    local shrinkDrop = TweenService:Create(DropDownForStartingFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 20)})
    shrinkDrop:Play()
    shrinkDrop.Completed:Wait()
    DropDownForStartingFrame.Visible = false

    MainHub.Position = UDim2.new(0.5, 0, 0.5, 0)
    MainHub.AnchorPoint = Vector2.new(0.5, 0.5)
    MainHub.Size = UDim2.new(0, 0, 0, 0)
    MainHub.Visible = true

    local explode = TweenService:Create(MainHub, TweenInfo.new(0.55, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 755, 0, 435)})
    explode:Play()
    explode.Completed:Wait()
    MainHub.AnchorPoint = Vector2.new(0, 0)

    task.wait(5)

    local minimizeHub = TweenService:Create(MainHub, TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(0, 117, 0, 31)})
    minimizeHub:Play()
    minimizeHub.Completed:Wait()

    local expandHub = TweenService:Create(MainHub, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 755, 0, 435)})
    expandHub:Play()
    expandHub.Completed:Wait()
end

local minimized = false
local minimizeConnection = nil

MinimizeBtn.MouseButton1Click:Connect(function()
    minimized = true
    MainHub.Visible = false
    if minimizeConnection then minimizeConnection:Disconnect() end
    minimizeConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.RightControl then
            minimized = false
            MainHub.Visible = true
            if minimizeConnection then
                minimizeConnection:Disconnect()
                minimizeConnection = nil
            end
        end
    end)
end)

ExitBtn.MouseButton1Click:Connect(function()
    if GameConfig.Script then
        GameConfig.Script()
    end
    task.wait(0.5)
    ScreenGui:Destroy()
end)

AutoScale()
RunService.RenderStepped:Connect(AutoScale)
PlayIntro()
SwitchTab(1)

if GameConfig.Script then
    GameConfig.Script()
end
