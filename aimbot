Circle.Transparency = 0.85
Circle.Visible = true

local OldNamecall = nil
local HookActive = false

-- Raycast Params (modern & faster)
local RaycastParams = RaycastParams.new()
RaycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
RaycastParams.FilterType = Enum.RaycastFilterType.Exclude
RaycastParams.IgnoreWater = true

local LastTargetUpdate = 0
local CachedTarget = nil

local function SameTeam(p)
    if not TeamCheck then return false end
    if not p.Team or not LocalPlayer.Team then return false end
    return p.Team == LocalPlayer.Team
end

local function IsVisible(part)
    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin) * 500
    local result = workspace:Raycast(origin, direction, RaycastParams)
    return result and result.Instance and result.Instance:IsDescendantOf(part.Parent)
end

local function GetClosest()
    local now = tick()
    if now - LastTargetUpdate < 0.08 and CachedTarget and CachedTarget.Parent then
        return CachedTarget
    end

    local closest = nil
    local shortest = FOV

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("Humanoid") then
            local hum = p.Character.Humanoid
            if hum.Health <= 0 then continue end
            if SameTeam(p) then continue end

            local part = p.Character:FindFirstChild(AimPart) or p.Character:FindFirstChild("HumanoidRootPart")
            if part then
                if not IsVisible(part) then continue end

                local vel = part.AssemblyLinearVelocity or Vector3.new()
                local predictedPos = part.Position + (vel * Prediction)

                local pos, onscreen = Camera:WorldToViewportPoint(predictedPos)
                if onscreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                    if dist < shortest then
                        shortest = dist
                        closest = part
                    end
                end
            end
        end
    end

    CachedTarget = closest
    LastTargetUpdate = now
    return closest
end

local function SetupSilentAim()
    if HookActive then return end
    HookActive = true

    OldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}

        if SilentAim and Enabled and method == "FireServer" then
            local name = self.Name:lower()
            if name:find("bullet") or name:find("shoot") or name:find("fire") or name:find("hit") or name:find("damage") then
                local targetPart = GetClosest()
                if targetPart then
                    local vel = targetPart.AssemblyLinearVelocity or Vector3.new()
                    local predictedPos = targetPart.Position + (vel * Prediction)

                    if #args >= 1 and typeof(args[1]) == "Vector3" then
                        args[1] = predictedPos
                    elseif #args >= 2 and typeof(args[2]) == "Vector3" then
                        args[2] = predictedPos
                    end
                end
            end
        end

        return OldNamecall(self, unpack(args))
    end))
end

SetupSilentAim()

local target = nil
RunService.RenderStepped:Connect(function()
    Circle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    Circle.Radius = FOV
    Circle.Visible = ShowCircle and Enabled

    if not Enabled then return end

    if not SilentAim then
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            target = GetClosest()
            if target then
                local goalCFrame = CFrame.new(Camera.CFrame.Position, target.Position)
                Camera.CFrame = Camera.CFrame:Lerp(goalCFrame, Smooth)
            end
        else
            target = nil
        end
    end
end)

