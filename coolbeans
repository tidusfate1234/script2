local function Initialize()
    print("Xeno Ultra - Initializing...")
    
    -- Create UI
    UI.Create()
    
    -- Create FOV circle
    CreateFOVCircle()
    
    -- Create watermark
    CreateWatermark()
    
    -- Apply world modifications
    ApplyWorldModifications()
    
    -- Start main loop
    RunService.RenderStepped:Connect(MainLoop)
    
    print("Xeno Ultra - Successfully loaded!")
    
    -- Notification
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Xeno Ultra",
        Text = "Advanced ESP & Aimbot System Loaded",
        Duration = 3
    })
end

-- Safe execution with error handling
local success, error = pcall(Initialize)
if not success then
    warn("Failed to initialize Xeno Ultra: " .. tostring(error))
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Xeno Ultra Error",
        Text = "Check console for details (F9)",
        Duration = 5
    })
end
