-- ========== WATERMARK & PERFORMANCE DISPLAY ==========
local Watermark = nil
local FPSCounter = nil

local function CreateWatermark()
    if not Config.UI.ShowWatermark then return end
    
    Watermark = Drawing.new("Text")
    Watermark.Text = "Xeno Ultra | Loaded"
    Watermark.Position = Vector2.new(10, 10)
    Watermark.Color = Color3.fromRGB(255, 255, 255)
    Watermark.Size = 14
    Watermark.Outline = true
    
    if Config.UI.ShowFPS then
        local frameTimes = {}
        local lastTime = tick()
        
        RunService.RenderStepped:Connect(function()
            local currentTime = tick()
            local delta = currentTime - lastTime
            lastTime = currentTime
            
            table.insert(frameTimes, delta)
            if #frameTimes > 60 then table.remove(frameTimes, 1) end
            
            local avgDelta = 0
            for _, dt in ipairs(frameTimes) do avgDelta = avgDelta + dt end
            avgDelta = avgDelta / #frameTimes
            
            local fps = math.floor(1 / avgDelta)
            Watermark.Text = string.format("Xeno Ultra | Loaded | FPS: %d", fps)
        end)
    end
end

