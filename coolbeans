-- ========== UTILITY FUNCTIONS ==========
local function GetClosestPlayerToCursor()
    local closestDistance = Config.Aimbot.FOVRadius
    local closestPlayer = nil
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and (Config.Aimbot.Teams or player.Team ~= LocalPlayer.Team) then
            local character = player.Character
            if character and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 then
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                if rootPart then
                    local screenPos, onScreen = Camera:WorldToScreenPoint(rootPart.Position)
                    if onScreen then
                        local distance = (Vector2.new(Mouse.X, Mouse.Y) - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                        if distance < closestDistance then
                            closestDistance = distance
                            closestPlayer = player
                        end
                    end
                end
            end
        end
    end
    
    return closestPlayer, closestDistance
end

local function IsVisible(part)
    if not Config.Aimbot.WallCheck then return true end
    
    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin).Unit
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {LocalPlayer.Character, part}
    
    local result = workspace:Raycast(origin, direction * (origin - part.Position).Magnitude, raycastParams)
    return result == nil
end

local function GetHitboxPosition(character, hitboxType)
    if hitboxType == "Head" then
        local head = character:FindFirstChild("Head")
        if head then return head.Position end
    elseif hitboxType == "Chest" then
        local upperTorso = character:FindFirstChild("UpperTorso")
        if upperTorso then return upperTorso.Position end
    end
    
    local root = character:FindFirstChild("HumanoidRootPart")
    if root then return root.Position end
    
    return nil
end

-- ========== ADVANCED AIMBOT LOGIC ==========
local Aimbot = {
    CurrentTarget = nil,
    LastAimTime = 0,
    
    Update = function()
        if not Config.Aimbot.Enabled then return end
        
        -- Check if aim key is held
        if not UserInputService:IsKeyDown(Enum.KeyCode[Config.Aimbot.Keybind]) then
            Aimbot.CurrentTarget = nil
            return
        end
        
        local target, distance = GetClosestPlayerToCursor()
        
        if target then
            local character = target.Character
            if character then
                local hitboxPos = GetHitboxPosition(character, Config.Aimbot.Hitbox)
                if hitboxPos then
                    -- Check distance
                    local actualDistance = (Camera.CFrame.Position - hitboxPos).Magnitude
                    if actualDistance <= Config.Aimbot.MaxDistance then
                        -- Check visibility
                        if IsVisible(character[Config.Aimbot.Hitbox] or character.HumanoidRootPart) then
                            Aimbot.CurrentTarget = target
                            
                            -- Predictive aiming
                            local velocity = character.HumanoidRootPart.Velocity
                            local predictedPos = hitboxPos + (velocity * Config.Aimbot.Prediction)
                            
                            -- Convert to screen coordinates
                            local screenPos, onScreen = Camera:WorldToScreenPoint(predictedPos)
                            if onScreen then
                                if Config.Aimbot.Silent then
                                    -- Silent aim (CFrame manipulation)
                                    local lookVector = (predictedPos - Camera.CFrame.Position).Unit
                                    local newCFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + lookVector)
                                    Camera.CFrame = Camera.CFrame:Lerp(newCFrame, Config.Aimbot.Smoothing)
                                else
                                    -- Visible aim (mouse movement)
                                    local mouseDelta = Vector2.new(screenPos.X - Mouse.X, screenPos.Y - Mouse.Y)
                                    mousemoverel(mouseDelta.X * Config.Aimbot.Smoothing, mouseDelta.Y * Config.Aimbot.Smoothing)
                                end
                            end
                        end
                    end
                end
            end
        else
            Aimbot.CurrentTarget = nil
        end
    end
}

-- ========== TRIGGERBOT LOGIC ==========
local Triggerbot = {
    LastShot = 0,
    
    Update = function()
        if not Config.Triggerbot.Enabled then return end
        if not UserInputService:IsKeyDown(Enum.KeyCode[Config.Triggerbot.HoldKey]) then return end
        
        local target, distance = GetClosestPlayerToCursor()
        
        if target and distance < 50 then -- Only trigger if crosshair is close
            local currentTime = tick()
            if currentTime - Triggerbot.LastShot >= Config.Triggerbot.Delay then
                -- Random hit chance
                if math.random(1, 100) <= Config.Triggerbot.HitChance then
                    -- Simulate mouse click
                    mouse1click()
                    Triggerbot.LastShot = currentTime
                end
            end
        end
    end
}

-- ========== ADVANCED ESP SYSTEM ==========
local ESP = {
    Drawings = {},
    
    CreateBox = function(player, character, rootPart, screenPos)
        local size = character:GetExtentsSize()
        local height = size.Y
        local width = size.X
        local depth = size.Z
        
        -- Calculate box corners
        local topLeft = Camera:WorldToScreenPoint(rootPart.Position + Vector3.new(-width, height/2, -depth))
        local bottomRight = Camera:WorldToScreenPoint(rootPart.Position + Vector3.new(width, -height/2, depth))
        
        if topLeft.Z > 0 and bottomRight.Z > 0 then
            local boxWidth = bottomRight.X - topLeft.X
            local boxHeight = bottomRight.Y - topLeft.Y
            
            -- Different box styles
            if Config.ESP.BoxType == "Full" then
                -- Full box rendering
                local drawing = Drawing.new("Square")
                drawing.Position = Vector2.new(topLeft.X, topLeft.Y)
                drawing.Size = Vector2.new(boxWidth, boxHeight)
                drawing.Color = Config.ESP.BoxColor
                drawing.Transparency = Config.ESP.BoxTransparency
                drawing.Thickness = 1
                drawing.Filled = false
                table.insert(ESP.Drawings, drawing)
                
            elseif Config.ESP.BoxType == "Corner" then
                -- Corner box (more common in FPS games)
                local cornerSize = math.min(boxWidth, boxHeight) * 0.25
                
                -- Top-left corner
                local tl1 = Drawing.new("Line")
                tl1.From = Vector2.new(topLeft.X, topLeft.Y + cornerSize)
                tl1.To = Vector2.new(topLeft.X, topLeft.Y)
                tl1.Color = Config.ESP.BoxColor
                tl1.Thickness = 2
                
                local tl2 = Drawing.new("Line")
                tl2.From = Vector2.new(topLeft.X, topLeft.Y)
                tl2.To = Vector2.new(topLeft.X + cornerSize, topLeft.Y)
                tl2.Color = Config.ESP.BoxColor
                tl2.Thickness = 2
                
                -- Top-right corner
                local tr1 = Drawing.new("Line")
                tr1.From = Vector2.new(topLeft.X + boxWidth, topLeft.Y + cornerSize)
                tr1.To = Vector2.new(topLeft.X + boxWidth, topLeft.Y)
                tr1.Color = Config.ESP.BoxColor
                tr1.Thickness = 2
                
                local tr2 = Drawing.new("Line")
                tr2.From = Vector2.new(topLeft.X + boxWidth, topLeft.Y)
                tr2.To = Vector2.new(topLeft.X + boxWidth - cornerSize, topLeft.Y)
                tr2.Color = Config.ESP.BoxColor
                tr2.Thickness = 2
                
                -- Bottom-left corner
                local bl1 = Drawing.new("Line")
                bl1.From = Vector2.new(topLeft.X, topLeft.Y + boxHeight - cornerSize)
                bl1.To = Vector2.new(topLeft.X, topLeft.Y + boxHeight)
                bl1.Color = Config.ESP.BoxColor
                bl1.Thickness = 2
                
                local bl2 = Drawing.new("Line")
                bl2.From = Vector2.new(topLeft.X, topLeft.Y + boxHeight)
                bl2.To = Vector2.new(topLeft.X + cornerSize, topLeft.Y + boxHeight)
                bl2.Color = Config.ESP.BoxColor
                bl2.Thickness = 2
                
                -- Bottom-right corner
                local br1 = Drawing.new("Line")
                br1.From = Vector2.new(topLeft.X + boxWidth, topLeft.Y + boxHeight - cornerSize)
                br1.To = Vector2.new(topLeft.X + boxWidth, topLeft.Y + boxHeight)
                br1.Color = Config.ESP.BoxColor
                br1.Thickness = 2
                
                local br2 = Drawing.new("Line")
                br2.From = Vector2.new(topLeft.X + boxWidth, topLeft.Y + boxHeight)
                br2.To = Vector2.new(topLeft.X + boxWidth - cornerSize, topLeft.Y + boxHeight)
                br2.Color = Config.ESP.BoxColor
                br2.Thickness = 2
                
                table.insert(ESP.Drawings, tl1, tl2, tr1, tr2, bl1, bl2, br1, br2)
            end
            
            -- Health bar
            if Config.ESP.Health.Enabled then
                local humanoid = character:FindFirstChild("Humanoid")
                if humanoid then
                    local healthPercent = humanoid.Health / humanoid.MaxHealth
                    local healthColor = Config.ESP.Health.ColorGood:Lerp(Config.ESP.Health.ColorBad, 1 - healthPercent)
                    
                    local healthBar = Drawing.new("Line")
                    healthBar.From = Vector2.new(topLeft.X - 5, topLeft.Y + boxHeight)
                    healthBar.To = Vector2.new(topLeft.X - 5, topLeft.Y + boxHeight - (boxHeight * healthPercent))
                    healthBar.Color = healthColor
                    healthBar.Thickness = 3
                    table.insert(ESP.Drawings, healthBar)
                end
            end
            
            return true
        end
        return false
    end,
    
    CreateSkeleton = function(player, character)
        if not Config.ESP.Skeleton.Enabled then return end
        
        -- Define bone connections
        local bones = {
            -- Head to shoulders
            {"Head", "UpperTorso"},
            -- Shoulders to hands
            {"UpperTorso", "LeftUpperArm"},
            {"LeftUpperArm", "LeftLowerArm"},
            {"LeftLowerArm", "LeftHand"},
            {"UpperTorso", "RightUpperArm"},
            {"RightUpperArm", "RightLowerArm"},
            {"RightLowerArm", "RightHand"},
            -- Spine to legs
            {"UpperTorso", "LowerTorso"},
            {"LowerTorso", "LeftUpperLeg"},
            {"LeftUpperLeg", "LeftLowerLeg"},
            {"LeftLowerLeg", "LeftFoot"},
            {"LowerTorso", "RightUpperLeg"},
            {"RightUpperLeg", "RightLowerLeg"},
            {"RightLowerLeg", "RightFoot"}
        }
        
        for _, bonePair in ipairs(bones) do
            local bone1 = character:FindFirstChild(bonePair[1])
            local bone2 = character:FindFirstChild(bonePair[2])
            
            if bone1 and bone2 then
                local pos1, onScreen1 = Camera:WorldToScreenPoint(bone1.Position)
                local pos2, onScreen2 = Camera:WorldToScreenPoint(bone2.Position)
                
                if onScreen1 and onScreen2 then
                    local line = Drawing.new("Line")
                    line.From = Vector2.new(pos1.X, pos1.Y)
                    line.To = Vector2.new(pos2.X, pos2.Y)
                    line.Color = Config.ESP.Skeleton.Color
                    line.Thickness = Config.ESP.Skeleton.Thickness
                    table.insert(ESP.Drawings, line)
                end
            end
        end
    end,
    
    CreateTextLabels = function(player, character, rootPart, screenPos)
        local yOffset = 0
        
        -- Player name
        if Config.ESP.Name.Enabled then
            local nameText = Drawing.new("Text")
            nameText.Text = player.Name
            nameText.Position = Vector2.new(screenPos.X, screenPos.Y - 30 - yOffset)
            nameText.Color = Config.ESP.Name.Color
            nameText.Size = Config.ESP.Name.Size
            nameText.Center = true
            nameText.Outline = Config.ESP.Outline
            table.insert(ESP.Drawings, nameText)
            yOffset = yOffset + 20
        end
        
        -- Distance
        if Config.ESP.Distance.Enabled then
            local distance = (Camera.CFrame.Position - rootPart.Position).Magnitude
            local distanceText = Drawing.new("Text")
            distanceText.Text = string.format("%.0fm", distance)
            distanceText.Position = Vector2.new(screenPos.X, screenPos.Y - 15 - yOffset)
            distanceText.Color = Config.ESP.Distance.Color
            distanceText.Size = 12
            distanceText.Center = true
            distanceText.Outline = Config.ESP.Outline
            table.insert(ESP.Drawings, distanceText)
            yOffset = yOffset + 15
        end
        
        -- Weapon
        if Config.ESP.Weapon.Enabled then
            local tool = character:FindFirstChildWhichIsA("Tool")
            if tool then
                local weaponText = Drawing.new("Text")
                weaponText.Text = tool.Name
                weaponText.Position = Vector2.new(screenPos.X, screenPos.Y + 10)
                weaponText.Color = Config.ESP.Weapon.Color
                weaponText.Size = 11
                weaponText.Center = true
                weaponText.Outline = Config.ESP.Outline
                table.insert(ESP.Drawings, weaponText)
            end
        end
    end,
    
    CreateHeadDot = function(player, character)
        if not Config.ESP.HeadDot.Enabled then return end
        
        local head = character:FindFirstChild("Head")
        if head then
            local headPos, onScreen = Camera:WorldToScreenPoint(head.Position)
            if onScreen then
                local dot = Drawing.new("Circle")
                dot.Position = Vector2.new(headPos.X, headPos.Y)
                dot.Radius = Config.ESP.HeadDot.Size
                dot.Color = Config.ESP.HeadDot.Color
                dot.Filled = true
                dot.Thickness = 0
                table.insert(ESP.Drawings, dot)
            end
        end
    end,
    
    CreateTracer = function(player, character, rootPart)
        if not Config.ESP.Tracer.Enabled then return end
        
        local screenPos, onScreen = Camera:WorldToScreenPoint(rootPart.Position)
        if onScreen then
            local startPos
            if Config.ESP.Tracer.StartPosition == "Bottom" then
                startPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
            elseif Config.ESP.Tracer.StartPosition == "Top" then
                startPos = Vector2.new(Camera.ViewportSize.X / 2, 0)
            else -- Crosshair
                startPos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
            end
            
            local tracer = Drawing.new("Line")
            tracer.From = startPos
            tracer.To = Vector2.new(screenPos.X, screenPos.Y)
            tracer.Color = Config.ESP.Tracer.Color
            tracer.Thickness = 1
            table.insert(ESP.Drawings, tracer)
        end
    end,
    
    Update = function()
        -- Clear previous drawings
        for _, drawing in ipairs(ESP.Drawings) do
            drawing:Remove()
        end
        ESP.Drawings = {}
        
        if not Config.ESP.Enabled then return end
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local character = player.Character
                if character and character:FindFirstChild("Humanoid") and character.Humanoid.Health > 0 then
                    local rootPart = character:FindFirstChild("HumanoidRootPart")
                    if rootPart then
                        local screenPos, onScreen = Camera:WorldToScreenPoint(rootPart.Position)
                        if onScreen then
                            -- Create all ESP elements
                            ESP.CreateBox(player, character, rootPart, screenPos)
                            ESP.CreateSkeleton(player, character)
                            ESP.CreateTextLabels(player, character, rootPart, screenPos)
                            ESP.CreateHeadDot(player, character)
                            ESP.CreateTracer(player, character, rootPart)
                        end
                    end
                end
            end
        end
    end
}

