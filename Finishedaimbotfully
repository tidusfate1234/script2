local function getCharacter(player)
    local char = player.Character
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    if hum and hum.Health > 0 and root then
        return char, hum, root
    end
    return nil
end

local function shouldHit()
    if Settings.HitChance >= 100 then return true end
    return math.random(1, 100) <= Settings.HitChance
end

local function isTeammate(player)
    if not Settings.TeamCheck then return false end
    if not player.Team or not LocalPlayer.Team then return false end
    return player.Team == LocalPlayer.Team
end

local function isVisible(part)
    if not Settings.VisibilityCheck then return true end
    if not part then return false end
    local origin = Camera.CFrame.Position
    local direction = part.Position - origin
    local distance = direction.Magnitude
    if distance > 650 then return false end
    
    local char = LocalPlayer.Character
    RaycastParams.FilterDescendantsInstances = char and {char} or {}
    local result = Workspace:Raycast(origin, direction.Unit * distance, RaycastParams)
    if not result then return true end
    local hitModel = result.Instance:FindFirstAncestorWhichIsA("Model")
    return hitModel == part.Parent
end

local function getCurrentWeapon()
    local char = LocalPlayer.Character
    return char and char:FindFirstChildWhichIsA("Tool")
end

local lastWeaponCheck = 0
local function forceInfiniteAmmo()
    if not Settings.InfiniteAmmo then return end
    local now = tick()
    if now - lastWeaponCheck < 0.15 then return end
    lastWeaponCheck = now
    
    local weapon = getCurrentWeapon()
    if not weapon then return end
    for _, v in ipairs(weapon:GetDescendants()) do
        if (v:IsA("IntValue") or v:IsA("NumberValue")) and v.Name:lower():match("ammo|bullet|clip|mag") then
            v.Value = 9999
        end
    end
end

local function applyWeaponMods()
    local weapon = getCurrentWeapon()
    if not weapon then return end
    for _, v in ipairs(weapon:GetDescendants()) do
        if v:IsA("NumberValue") then
            local name = v.Name:lower()
            if Settings.NoSpread and name:match("spread|accuracy") then
                v.Value = 0
            end
            if Settings.NoRecoil and name:match("recoil|kick") then
                v.Value = 0
            end
            if Settings.RapidFire and name:match("firerate|fire_rate") then
                v.Value = v.Value / Settings.FireRateMultiplier
            end
            if Settings.InstantEquip and name:match("equip|draw") then
                v.Value = 0.01
            end
        end
    end
end

local function setupHooks()
    pcall(function()
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        setreadonly(mt, false)
        
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            if method == "FireServer" and Settings.Enabled and Settings.SilentAim and shouldHit() then
                if self:IsA("RemoteEvent") then
                    local name = self.Name:lower()
                    if name:find("shoot") or name:find("fire") or name:find("bullet") or (self.Parent and self.Parent:IsA("Tool")) then
                        local target = LockedTarget
                        if target and isVisible(target) then
                            local targetPos = target.Position
                            if Settings.Prediction > 0 then
                                local vel = target.Velocity or target.AssemblyLinearVelocity or Vector3.zero
                                targetPos = targetPos + vel * Settings.Prediction
                            end
                            if math.random() < 0.15 then
                                targetPos = targetPos + Vector3.new(math.random(-1, 1), math.random(-1, 1), math.random(-1, 1))
                            end
                            
                            for i = 1, #args do
                                local arg = args[i]
                                if typeof(arg) == "Vector3" then
                                    args[i] = targetPos
                                    break
                                elseif typeof(arg) == "CFrame" then
                                    args[i] = CFrame.new(targetPos)
                                    break
                                elseif typeof(arg) == "table" then
                                    if arg.Position then
                                        arg.Position = targetPos
                                    elseif arg.hit and arg.hit.Position then
                                        arg.hit.Position = targetPos
                                    end
                                    break
                                end
                            end
                        end
                    end
                end
            end
            
            if Settings.NoReload and method == "FireServer" then
                local name = self.Name:lower()
                if name:find("reload") or name:find("ammo") then
                    return
                end
            end
            
            return old(self, unpack(args))
        end)
        
        setreadonly(mt, true)
        OldNamecall = old
    end)
end
setupHooks()

local function createESP(player)
    if ESPCache[player] then return end
    
    local esp = {
        BoxOutline = Drawing.new("Square"),
        Box = Drawing.new("Square"),
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        HealthBar = Drawing.new("Square"),
        HealthFill = Drawing.new("Square"),
        HeadDot = Drawing.new("Circle"),
        Snapline = Drawing.new("Line")
    }
    
    esp.BoxOutline.Thickness = 3
    esp.BoxOutline.Filled = false
    esp.BoxOutline.Color = Color3.new(0, 0, 0)
    
    esp.Box.Thickness = 1
    esp.Box.Filled = false
    
    esp.Name.Size = 13
    esp.Name.Center = true
    esp.Name.Outline = true
    esp.Name.Font = 2
    
    esp.Distance.Size = 12
    esp.Distance.Center = true
    esp.Distance.Outline = true
    
    esp.HealthBar.Thickness = 1
    esp.HealthBar.Filled = false
    esp.HealthBar.Color = Color3.new(0, 0, 0)
    
    esp.HealthFill.Thickness = 1
    esp.HealthFill.Filled = true
    
    esp.HeadDot.Radius = 4
    esp.HeadDot.Filled = true
    
    esp.Snapline.Thickness = 1
    
    ESPCache[player] = esp
end

local function updateESP()
    if not Settings.ESPEnabled then
        for _, esp in pairs(ESPCache) do
            for _, d in pairs(esp) do
                d.Visible = false
            end
        end
        return
    end
    
    local now = tick()
    if now - LastESPUpdate < Settings.ESPRefreshRate then return end
    LastESPUpdate = now
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char, hum, root = getCharacter(player)
        
        if not char then
            if ESPCache[player] then
                for _, d in pairs(ESPCache[player]) do
                    pcall(function() d:Remove() end)
                end
                ESPCache[player] = nil
            end
            continue
        end
        
        createESP(player)
        local esp = ESPCache[player]
        local isTeam = isTeammate(player)
        local color = isTeam and Settings.ESPTeamColor or Settings.ESPColor
        
        local head = char:FindFirstChild("Head")
        if not head or not root or not hum then continue end
        
        local headPos, onScreen = Camera:WorldToViewportPoint(head.Position)
        if not onScreen then
            for _, d in pairs(esp) do d.Visible = false end
            continue
        end
        
        local boxHeight = (head.Position.Y - root.Position.Y) * 2.2
        local top = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, boxHeight * 0.15, 0))
        local bottom = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, boxHeight * 0.3, 0))
        local height = math.abs(top.Y - bottom.Y)
        local width = height * 0.55
        local boxPos = Vector2.new(top.X - width / 2, top.Y)
        
        if Settings.ESPBoxes then
            esp.BoxOutline.Size = Vector2.new(width, height)
            esp.BoxOutline.Position = boxPos
            esp.BoxOutline.Visible = true
            esp.Box.Size = Vector2.new(width, height)
            esp.Box.Position = boxPos
            esp.Box.Color = color
            esp.Box.Visible = true
        else
            esp.BoxOutline.Visible = false
            esp.Box.Visible = false
        end
        
        if Settings.ESPNames then
            esp.Name.Text = player.Name
            esp.Name.Position = Vector2.new(boxPos.X + width / 2, boxPos.Y - 20)
            esp.Name.Color = color
            esp.Name.Visible = true
        else
            esp.Name.Visible = false
        end
        
        if Settings.ESPDistance then
            local dist = math.floor((Camera.CFrame.Position - root.Position).Magnitude)
            esp.Distance.Text = dist .. "m"
            esp.Distance.Position = Vector2.new(boxPos.X + width / 2, boxPos.Y + height + 4)
            esp.Distance.Color = color
            esp.Distance.Visible = true
        else
            esp.Distance.Visible = false
        end
        
        if Settings.ESPHealth then
            local hp = hum.Health / hum.MaxHealth
            local barPos = Vector2.new(boxPos.X - 6, boxPos.Y)
            esp.HealthBar.Size = Vector2.new(3, height)
            esp.HealthBar.Position = barPos
            esp.HealthBar.Visible = true
            esp.HealthFill.Size = Vector2.new(3, height * hp)
            esp.HealthFill.Position = Vector2.new(barPos.X, barPos.Y + height * (1 - hp))
            esp.HealthFill.Color = Color3.fromRGB(255 * (1 - hp), 255 * hp, 0)
            esp.HealthFill.Visible = true
        else
            esp.HealthBar.Visible = false
            esp.HealthFill.Visible = false
        end
        
        if Settings.ESPHeadDot then
            esp.HeadDot.Position = Vector2.new(headPos.X, headPos.Y)
            esp.HeadDot.Color = color
            esp.HeadDot.Visible = true
        else
            esp.HeadDot.Visible = false
        end
        
        if Settings.ESPSnaplines then
            local vs = Camera.ViewportSize
            esp.Snapline.From = Vector2.new(vs.X / 2, vs.Y)
            esp.Snapline.To = Vector2.new(bottom.X, bottom.Y)
            esp.Snapline.Color = color
            esp.Snapline.Visible = true
        else
            esp.Snapline.Visible = false
        end
    end
end

local function findTarget()
    local now = tick()
    if now - LastScanTime < Settings.ScanInterval then
        return LockedTarget, LockedPlayer
    end
    LastScanTime = now
    
    if LockedTarget and LockedPlayer then
        local char = getCharacter(LockedPlayer)
        if char and not isTeammate(LockedPlayer) then
            local part = char:FindFirstChild(Settings.AimPart) or char:FindFirstChild("Head")
            if part and isVisible(part) then
                local sp, on = Camera:WorldToViewportPoint(part.Position)
                if on and (Vector2.new(sp.X, sp.Y) - Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)).Magnitude < Settings.FOV then
                    return LockedTarget, LockedPlayer
                end
            end
        end
        LockedTarget = nil
        LockedPlayer = nil
    end
    
    local bestDist = Settings.FOV
    local bestTarget, bestPlayer = nil, nil
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = getCharacter(player)
        if not char or isTeammate(player) then continue end
        local part = char:FindFirstChild(Settings.AimPart) or char:FindFirstChild("Head")
        if part and isVisible(part) then
            local sp, onScreen = Camera:WorldToViewportPoint(part.Position)
            if onScreen then
                local dist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    bestTarget = part
                    bestPlayer = player
                end
            end
        end
    end
    
    LockedTarget = bestTarget
    LockedPlayer = bestPlayer
    return bestTarget, bestPlayer
end

local function updateCrosshair()
    if not Settings.Crosshair then
        for _, line in pairs(CrosshairLines) do line.Visible = false end
        return
    end
    
    local vs = Camera.ViewportSize
    local c = Vector2.new(vs.X / 2, vs.Y / 2)
    local s, g = Settings.CrosshairSize, Settings.CrosshairGap
    
    CrosshairLines.Top.From = Vector2.new(c.X, c.Y - g)
    CrosshairLines.Top.To = Vector2.new(c.X, c.Y - g - s)
    CrosshairLines.Bottom.From = Vector2.new(c.X, c.Y + g)
    CrosshairLines.Bottom.To = Vector2.new(c.X, c.Y + g + s)
    CrosshairLines.Left.From = Vector2.new(c.X - g, c.Y)
    CrosshairLines.Left.To = Vector2.new(c.X - g - s, c.Y)
    CrosshairLines.Right.From = Vector2.new(c.X + g, c.Y)
    CrosshairLines.Right.To = Vector2.new(c.X + g + s, c.Y)
    
    for _, line in pairs(CrosshairLines) do
        line.Color = Settings.CrosshairColor
        line.Visible = true
    end
end

Connections.Heartbeat = RunService.Heartbeat:Connect(function()
    forceInfiniteAmmo()
    applyWeaponMods()
    if Settings.FOVChanger then Camera.FieldOfView = Settings.CustomFOV end
    if Settings.ThirdPerson and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.CameraOffset = Vector3.new(0, 0, -Settings.ThirdPersonDistance)
        end
    end
end)

Connections.RenderStepped = RunService.RenderStepped:Connect(function()
    updateESP()
    updateCrosshair()
    
    local vs = Camera.ViewportSize
    FOVCircle.Position = Vector2.new(vs.X / 2, vs.Y / 2)
    FOVCircle.Radius = Settings.FOV
    FOVCircle.Visible = Settings.Enabled and Settings.ShowFOV
    FOVCircle.Color = Settings.FOVColor
    
    if not Settings.Enabled then return end
    
    local target, _ = findTarget()
    if not target then return end
    
    if not Settings.SilentAim and shouldHit() then
        local targetCF = CFrame.new(Camera.CFrame.Position, target.Position)
        Camera.CFrame = Camera.CFrame:Lerp(targetCF, Settings.Smoothing)
    elseif Settings.AimAssist and not Settings.SilentAim and shouldHit() then
        local targetCF = CFrame.new(Camera.CFrame.Position, target.Position)
        Camera.CFrame = Camera.CFrame:Lerp(targetCF, Settings.AimAssistStrength)
    end
    
    if Settings.TriggerBot and Settings.AutoShoot and shouldHit() and isVisible(target) then
        local now = tick()
        if now - LastTriggerTime >= Settings.TriggerDelay then
            LastTriggerTime = now
            local mp = UserInputService:GetMouseLocation()
            VirtualInputManager:SendMouseButtonEvent(mp.X, mp.Y, 0, true, game, 1)
            task.wait(0.008)
            VirtualInputManager:SendMouseButtonEvent(mp.X, mp.Y, 0, false, game, 1)
        end
    end
end)

