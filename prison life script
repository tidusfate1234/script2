local function FullCleanup()
    for _, conn in ipairs(weaponConnections) do pcall(function() conn:Disconnect() end) end
    weaponConnections = {}
    for _, conn in ipairs(flyConnections) do pcall(function() conn:Disconnect() end) end
    flyConnections = {}
    if flyConnection then pcall(function() flyConnection:Disconnect() end) flyConnection = nil end
    for _, obj in ipairs(flyObjects) do pcall(function() obj:Destroy() end) end
    flyObjects = {}
    local char = LocalPlayer.Character
    if char then
        local hm = char:FindFirstChildOfClass("Humanoid")
        if hm then hm.PlatformStand = false end
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("BodyVelocity") or v:IsA("BodyGyro") then pcall(function() v:Destroy() end) end
        end
    end
    for _, esp in pairs(ESPCache) do
        for _, obj in pairs(esp) do
            pcall(function() if obj.Destroy then obj:Destroy() elseif obj.Remove then obj:Remove() end end)
        end
    end
    ESPCache = {}
    if silentAimHooked and oldNamecall then
        pcall(function()
            local mt = getrawmetatable(game)
            setreadonly(mt, false)
            mt.__namecall = oldNamecall
            setreadonly(mt, true)
        end)
        silentAimHooked = false
    end
end

local function GetCharacter(Player)
    local Char = Player.Character
    if not Char then return nil end
    local hm = Char:FindFirstChildOfClass("Humanoid")
    local root = Char:FindFirstChild("HumanoidRootPart")
    return (hm and hm.Health > 0 and root) and Char or nil
end

local function IsVisible(Part)
    if not Settings.VisibilityCheck then return true end
    if not Part then return false end
    local Origin = Camera.CFrame.Position
    local Direction = (Part.Position - Origin)
    local Distance = Direction.Magnitude
    if Distance > 500 then return false end
    local ignoreList = {LocalPlayer.Character}
    local targetModel = Part.Parent
    if targetModel and targetModel:IsA("Model") then table.insert(ignoreList, targetModel) end
    RaycastParamsObj.FilterDescendantsInstances = ignoreList
    local Result = Workspace:Raycast(Origin, Direction.Unit * Distance, RaycastParamsObj)
    if not Result then return true end
    local HitModel = Result.Instance:FindFirstAncestorWhichIsA("Model")
    return HitModel and HitModel == Part.Parent
end

-- ESP
local function CreateESP(Player)
    if ESPCache[Player] then return end
    if not Settings.ESP then return end
    local esp = {}
    pcall(function()
        esp.BoxOutline = Drawing.new("Square"); esp.Box = Drawing.new("Square")
        esp.Name = Drawing.new("Text"); esp.HealthBar = Drawing.new("Square")
        esp.HealthFill = Drawing.new("Square")
        esp.BoxOutline.Thickness = 3; esp.BoxOutline.Filled = false
        esp.Box.Thickness = 1; esp.Box.Filled = false
        esp.Name.Size = 13; esp.Name.Center = true; esp.Name.Outline = true
        esp.HealthBar.Thickness = 1; esp.HealthBar.Filled = false
        esp.HealthFill.Thickness = 1; esp.HealthFill.Filled = true
        ESPCache[Player] = esp
    end)
end

local function RemoveESP(Player)
    local esp = ESPCache[Player]
    if not esp then return end
    for _, obj in pairs(esp) do pcall(function() if obj.Destroy then obj:Destroy() elseif obj.Remove then obj:Remove() end end) end
    ESPCache[Player] = nil
end

local function ClearAllESP()
    for _, esp in pairs(ESPCache) do
        for _, obj in pairs(esp) do pcall(function() if obj.Destroy then obj:Destroy() elseif obj.Remove then obj:Remove() end end) end
    end
    ESPCache = {}
end

local function UpdateESP()
    if not Settings.ESP then ClearAllESP(); return end
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player == LocalPlayer then continue end
        local Character = GetCharacter(Player)
        if not Character then RemoveESP(Player); continue end
        CreateESP(Player)
        local esp = ESPCache[Player]
        if not esp then continue end
        local IsEnemy = (Player.Team or nil) ~= (LocalPlayer.Team or nil)
        local Color = IsEnemy and Color3.fromRGB(255, 0, 0) or Color3.fromRGB(0, 255, 0)
        local Head = Character:FindFirstChild("Head")
        local Root = Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if Head and Root and Humanoid then
            local HeadPos, OnScreen = Camera:WorldToViewportPoint(Head.Position)
            local RootPos = Camera:WorldToViewportPoint(Root.Position)
            if not OnScreen then for _, obj in pairs(esp) do if obj then obj.Visible = false end end continue end
            local Height = math.abs(HeadPos.Y - RootPos.Y) * 2.2
            local Width = Height * 0.55
            local BoxPos = Vector2.new(HeadPos.X - Width/2, HeadPos.Y - Height*0.05)
            if Settings.ESPBoxes and esp.BoxOutline and esp.Box then
                esp.BoxOutline.Size = Vector2.new(Width, Height); esp.BoxOutline.Position = BoxPos; esp.BoxOutline.Color = Color3.new(0,0,0); esp.BoxOutline.Visible = true
                esp.Box.Size = Vector2.new(Width, Height); esp.Box.Position = BoxPos; esp.Box.Color = Color; esp.Box.Visible = true
            end
            if Settings.ESPNames and esp.Name then
                esp.Name.Text = Player.Name; esp.Name.Position = Vector2.new(HeadPos.X, BoxPos.Y - 18); esp.Name.Color = Color; esp.Name.Visible = true
            end
            if Settings.ESPHealth and esp.HealthBar and esp.HealthFill then
                local hp = Humanoid.Health / Humanoid.MaxHealth
                local BarX = math.clamp(BoxPos.X - 8, 0, Camera.ViewportSize.X)
                esp.HealthBar.Size = Vector2.new(3, Height); esp.HealthBar.Position = Vector2.new(BarX, BoxPos.Y); esp.HealthBar.Color = Color3.new(0,0,0); esp.HealthBar.Visible = true
                esp.HealthFill.Size = Vector2.new(3, Height * hp); esp.HealthFill.Position = Vector2.new(BarX, BoxPos.Y + Height*(1-hp)); esp.HealthFill.Color = Color3.fromRGB(255*(1-hp), 255*hp, 0); esp.HealthFill.Visible = true
            end
        end
    end
end

-- Aimbot
local function FindTarget()
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local bestScore = Settings.AimbotFOV
    local bestPart = nil
    for _, Player in ipairs(Players:GetPlayers()) do
        if Player == LocalPlayer or (Player.Team or nil) == (LocalPlayer.Team or nil) then continue end
        local Char = GetCharacter(Player)
        if not Char then continue end
        local Part = Char:FindFirstChild("Head")
        if not Part or not IsVisible(Part) then continue end
        local sp, onScreen = Camera:WorldToViewportPoint(Part.Position)
        if onScreen then
            local screenDist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
            if screenDist < bestScore then bestScore = screenDist; bestPart = Part end
        end
    end
    return bestPart
end

-- God Weapons
local function processWeapon(tool)
    if not tool:IsA("Tool") or tool:GetAttribute("ToolType") ~= "Gun" then return end
    for stat, value in pairs(godWeaponStats) do pcall(function() tool:SetAttribute(stat, value) end) end
    pcall(function() tool:SetAttribute("CurrentAmmo", 999) end)
    pcall(function() tool:SetAttribute("Local_CurrentAmmo", 999) end)
    pcall(function() tool:SetAttribute("Local_ReloadSession", 0) end)
end

local function setupSilentAim()
    if silentAimHooked then return end
    pcall(function()
        local mt = getrawmetatable(game)
        oldNamecall = mt.__namecall
        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            if method == "FireServer" and self == GunRemotes.ShootEvent and Settings.GodWeapons then
                local data = args[1]
                if data and type(data) == "table" then
                    local closest, closestDist = nil, 500
                    local myHead = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head")
                    if myHead then
                        for _, player in ipairs(Players:GetPlayers()) do
                            if player ~= LocalPlayer and (player.Team or nil) ~= (LocalPlayer.Team or nil) then
                                local char = player.Character
                                if char then
                                    local head = char:FindFirstChild("Head")
                                    if head then
                                        local dist = (head.Position - myHead.Position).Magnitude
                                        if dist < closestDist then closestDist = dist; closest = head end
                                    end
                                end
                            end
                        end
                    end
                    if closest then
                        for i, shot in ipairs(data) do
                            if type(shot) == "table" then
                                data[i][2] = closest.Position
                                if #shot >= 3 then data[i][3] = closest.Parent end
                            end
                        end
                    end
                end
            end
            return oldNamecall(self, unpack(args))
        end)
        setreadonly(mt, true)
        silentAimHooked = true
    end)
end

local function setupGodWeapons()
    for _, conn in ipairs(weaponConnections) do pcall(function() conn:Disconnect() end) end
    weaponConnections = {}
    if not Settings.GodWeapons then
        if silentAimHooked and oldNamecall then
            pcall(function() local mt = getrawmetatable(game); setreadonly(mt, false); mt.__namecall = oldNamecall; setreadonly(mt, true) end)
            silentAimHooked = false
        end
        return
    end
    setupSilentAim()
    if LocalPlayer.Character then for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do if tool:IsA("Tool") then processWeapon(tool) end end end
    table.insert(weaponConnections, LocalPlayer.CharacterAdded:Connect(function(char)
        task.wait(0.1)
        for _, tool in ipairs(char:GetChildren()) do if tool:IsA("Tool") then processWeapon(tool) end end
        table.insert(weaponConnections, char.ChildAdded:Connect(function(child)
            if child:IsA("Tool") then task.wait(0.05); processWeapon(child) end
        end))
    end))
end

-- Kill Aura
local function KillAura()
    if not Settings.KillAura then return end
    if tick() - LastKillAura < Settings.KillAuraDelay then return end
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer or (player.Team or nil) == (LocalPlayer.Team or nil) then continue end
        local targetChar = player.Character
        if not targetChar then continue end
        local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
        if not targetRoot then continue end
        if (root.Position - targetRoot.Position).Magnitude < Settings.KillAuraRange then
            pcall(function() local me = ReplicatedStorage:FindFirstChild("meleeEvent"); if me then me:FireServer(targetChar, 1, 1) end end)
            LastKillAura = tick(); break
        end
    end
end

-- Kill All (shoots everyone regardless of distance)
local function KillAll()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and (player.Team or nil) ~= (LocalPlayer.Team or nil) then
            local char = player.Character
            if char then
                local head = char:FindFirstChild("Head")
                if head then
                    local shootData = {{LocalPlayer.Character.Head.Position, head.Position, char}}
                    pcall(function() GunRemotes.ShootEvent:FireServer(shootData) end)
                end
            end
        end
    end
end

-- Teleport
local function TeleportToTree()
    local TreeFolder = workspace:FindFirstChild("TreeFolder")
    if not TreeFolder then return end
    local trees = {}
    for _, tree in ipairs(TreeFolder:GetChildren()) do if tree.Name:find("tree") then table.insert(trees, tree) end end
    if #trees == 0 then return end
    local char = LocalPlayer.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then root.CFrame = CFrame.new(trees[math.random(1, #trees)]:GetPivot().Position + Vector3.new(0, 8, 0)) end
    end
end

-- Fly
local function setupFly()
    for _, conn in ipairs(flyConnections) do pcall(function() conn:Disconnect() end) end
    flyConnections = {}
    if flyConnection then pcall(function() flyConnection:Disconnect() end) flyConnection = nil end
    for _, obj in ipairs(flyObjects) do pcall(function() obj:Destroy() end) end
    flyObjects = {}
    local char = LocalPlayer.Character
    if char then
        local hm = char:FindFirstChildOfClass("Humanoid"); if hm then hm.PlatformStand = false end
        for _, v in ipairs(char:GetDescendants()) do if v:IsA("BodyVelocity") or v:IsA("BodyGyro") then pcall(function() v:Destroy() end) end end
    end
    if not Settings.FlyEnabled then return end
    local function startFlight(ch)
        local root = ch:FindFirstChild("HumanoidRootPart"); local hm = ch:FindFirstChildOfClass("Humanoid")
        if not root or not hm then return end
        hm.PlatformStand = true
        local bv = Instance.new("BodyVelocity"); bv.MaxForce = Vector3.new(1e6,1e6,1e6); bv.Velocity = Vector3.zero; bv.Parent = root; table.insert(flyObjects, bv)
        local bg = Instance.new("BodyGyro"); bg.MaxTorque = Vector3.new(1e6,1e6,1e6); bg.CFrame = root.CFrame; bg.Parent = root; table.insert(flyObjects, bg)
        flyConnection = RunService.RenderStepped:Connect(function()
            if not Settings.FlyEnabled or not root.Parent then for _, obj in ipairs(flyObjects) do pcall(function() obj:Destroy() end) end; flyObjects = {}; if flyConnection then flyConnection:Disconnect() end; if hm and hm.Parent then hm.PlatformStand = false end; return end
            local md = Vector3.zero
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then md += Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then md -= Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then md -= Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then md += Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then md += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then md -= Vector3.new(0,1,0) end
            if md.Magnitude > 0 then md = md.Unit end
            bv.Velocity = md * Settings.FlySpeed; bg.CFrame = Camera.CFrame
        end)
    end
    if LocalPlayer.Character then startFlight(LocalPlayer.Character) end
    table.insert(flyConnections, LocalPlayer.CharacterAdded:Connect(function(ch) task.wait(0.3); if Settings.FlyEnabled then startFlight(ch) end end))
end

