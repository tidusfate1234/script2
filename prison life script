-- Loops
RunService.Heartbeat:Connect(function(dt)
    LastWeaponCheck += dt
    if LastWeaponCheck >= 0.25 and Settings.GodWeapons then
        LastWeaponCheck = 0
        if LocalPlayer.Character then for _, tool in ipairs(LocalPlayer.Character:GetChildren()) do if tool:IsA("Tool") then processWeapon(tool) end end end
    end
    if Settings.KillAura then LastKillAura += dt; if LastKillAura >= Settings.KillAuraDelay then LastKillAura = 0; KillAura() end end
end)

RunService.RenderStepped:Connect(function()
    UpdateESP()
    if Settings.Aimbot then local target = FindTarget(); if target then Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Position), Settings.AimbotSmoothing) end end
end)

