                hrp.Velocity = Vector3.new(0, 25, 0)
            end
        end
    end)
end

local function UpdateAutoParry()
    if ParryConnection then ParryConnection:Disconnect(); ParryConnection = nil end
    if not Settings.AutoParry then return end
    ParryConnection = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local myRoot = char:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        for _, killer in ipairs(KillerFolder:GetChildren()) do
            local kRoot = killer:FindFirstChild("HumanoidRootPart")
            if not kRoot then continue end
            if GetDistance(myRoot, kRoot) > 30 then continue end
            local hum = killer:FindFirstChildOfClass("Humanoid")
            if not hum then continue end
            for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
                if track.IsPlaying and track.Animation and attackIds[track.Animation.AnimationId] then
                    FireAbility(2)
                    return
                end
            end
        end
    end)
end

local function UpdateAutoCombo()
    if ComboConnection then ComboConnection:Disconnect(); ComboConnection = nil end
    if not Settings.AutoCombo then return end
    ComboConnection = RunService.Heartbeat:Connect(function()
        if not IsKiller() then return end
        local survivor = GetNearestSurvivor()
        if not survivor then return end
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local sRoot = survivor:FindFirstChild("HumanoidRootPart")
        if not myRoot or not sRoot then return end
        if GetDistance(myRoot, sRoot) <= Settings.KillAuraRange then
            FireAbility(1)
            task.wait(Settings.ComboSpeed)
            FireAbility(2)
            task.wait(Settings.ComboSpeed)
        end
    end)
end

local function UpdateAutoDodge()
    if DodgeConnection then DodgeConnection:Disconnect(); DodgeConnection = nil end
    if not Settings.AutoDodge then return end
    DodgeConnection = RunService.Heartbeat:Connect(function()
        if not IsSurvivor() then return end
        local killer = GetNearestKiller()
        if not killer then return end
        local char = LocalPlayer.Character
        if not char then return end
        local myRoot = char:FindFirstChild("HumanoidRootPart")
        local kRoot = killer:FindFirstChild("HumanoidRootPart")
        if not myRoot or not kRoot then return end
        if GetDistance(myRoot, kRoot) <= Settings.DodgeRange then
            local direction = (myRoot.Position - kRoot.Position).Unit
            myRoot.CFrame = CFrame.new(myRoot.Position + direction * 15)
        end
    end)
end

local function UpdateAntiDeath()
    if AntiDeathConnection then AntiDeathConnection:Disconnect(); AntiDeathConnection = nil end
    if not Settings.AntiDeath then return end
    LastHealth = nil
    AntiDeathConnection = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end
        if not LastHealth then LastHealth = hum.Health; return end
        if hum.Health < LastHealth and hum.Health > 0 and not Teleported and not AntiDeathDebounce then
            AntiDeathDebounce = true
            Teleported = true
            LastSafePos = hrp.CFrame
            local pos = hrp.Position
            SafePlate = Instance.new("Part")
            SafePlate.Size = Vector3.new(50, 1, 50)
            SafePlate.Anchored = true
            SafePlate.Position = pos - Vector3.new(0, 100, 0)
            SafePlate.Parent = workspace
            hrp.CFrame = CFrame.new(pos - Vector3.new(0, 95, 0))
            task.delay(1, function() AntiDeathDebounce = false end)
        elseif hum.Health >= LastHealth and Teleported and LastSafePos and not AntiDeathDebounce then
            AntiDeathDebounce = true
            if SafePlate then SafePlate:Destroy(); SafePlate = nil end
            hrp.CFrame = LastSafePos
            LastSafePos = nil
            Teleported = false
            task.delay(1, function() AntiDeathDebounce = false end)
        end
        LastHealth = hum.Health
    end)
end

local function UpdateAntiDomain()
    if AntiDomainConnection then AntiDomainConnection:Disconnect(); AntiDomainConnection = nil end
    if not Settings.AntiDomain then return end
    AntiDomainConnection = RunService.RenderStepped:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            local otherChar = player.Character
            if not otherChar then continue end
            local otherRoot = otherChar:FindFirstChild("HumanoidRootPart")
            local otherHum = otherChar:FindFirstChildOfClass("Humanoid")
            if not otherRoot or not otherHum then continue end
            local dist = GetDistance(hrp, otherRoot)
            if dist > 50 then continue end
            for _, track in ipairs(otherHum:GetPlayingAnimationTracks()) do
                if track.IsPlaying and track.Animation and domainIds[track.Animation.AnimationId] then
                    local direction = (hrp.Position - otherRoot.Position).Unit
                    hrp.CFrame = CFrame.new(otherRoot.Position + direction * 75)
                    return
                end
            end
        end
    end)
end

local function UpdateLockOn()
    if LockOnConnection then LockOnConnection:Disconnect(); LockOnConnection = nil end
    if not Settings.LockOn then
        LockOnTarget = nil
        return
    end
    LockOnConnection = RunService.RenderStepped:Connect(function()
        if LockOnTarget and LockOnTarget.Parent then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, LockOnTarget.Position)
        else
            LockOnTarget = nil
        end
    end)
    UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            if LockOnTarget then
                LockOnTarget = nil
                return
            end
            local char = LocalPlayer.Character
            if not char then return end
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            local closest = nil
            local shortest = math.huge
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
                    if targetRoot then
                        local dist = GetDistance(hrp, targetRoot)
                        if dist < shortest then
                            shortest = dist
                            closest = targetRoot
                        end
                    end
                end
            end
            LockOnTarget = closest
        end
    end)
end

