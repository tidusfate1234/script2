end

local function UpdateESP()
    ClearHighlights()
    if not Settings.ESPEnabled then return end
    if Settings.SurvivorESP then
        for _, s in ipairs(AliveFolder:GetChildren()) do
            if s ~= LocalPlayer.Character then CreateHighlight(s, Color3.fromRGB(80, 180, 255)) end
        end
    end
    if Settings.KillerESP then
        for _, k in ipairs(KillerFolder:GetChildren()) do
            CreateHighlight(k, Color3.fromRGB(255, 80, 80))
        end
    end
    if Settings.GeneratorESP then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj.Name == "Generator" then CreateHighlight(obj, Color3.fromRGB(0, 255, 100)) end
        end
    end
    if Settings.BatteryESP then
        local ignore = workspace:FindFirstChild("IGNORE")
        if ignore then
            for _, obj in ipairs(ignore:GetDescendants()) do
                if obj:IsA("MeshPart") and obj.Name == "Battery" then CreateHighlight(obj, Color3.fromRGB(255, 0, 255)) end
            end
        end
    end
    if Settings.FuseBoxESP then
        local maps = workspace:FindFirstChild("MAPS")
        if maps then
            local gameMap = maps:FindFirstChild("GAME MAP")
            if gameMap then
                local tasks = gameMap:FindFirstChild("Tasks")
                if tasks then
                    local fuseBoxes = tasks:FindFirstChild("FuseBoxes")
                    if fuseBoxes then
                        for _, fb in ipairs(fuseBoxes:GetChildren()) do
                            if fb:IsA("Model") then CreateHighlight(fb, Color3.fromRGB(0, 255, 255)) end
                        end
                    end
                end
            end
        end
    end
    if Settings.TrapESP then
        local ignore = workspace:FindFirstChild("IGNORE")
        if ignore then
            for _, obj in ipairs(ignore:GetChildren()) do
                if obj:IsA("Model") and obj.Name:lower():find("trap") then CreateHighlight(obj, Color3.fromRGB(255, 100, 0)) end
            end
        end
    end
    if Settings.MinionESP then
        local ignore = workspace:FindFirstChild("IGNORE")
        if ignore then
            for _, obj in ipairs(ignore:GetDescendants()) do
                if obj:IsA("Model") and obj.Name == "Minion" then CreateHighlight(obj, Color3.fromRGB(255, 165, 0)) end
            end
        end
    end
    if Settings.ItemESP then
        local items = workspace:FindFirstChild("Items")
        if items then
            for _, obj in ipairs(items:GetDescendants()) do
                if obj:IsA("BasePart") then CreateHighlight(obj, Color3.fromRGB(255, 0, 0)) end
            end
        end
    end
end

local function UpdateSpeed()
    if SpeedConnection then SpeedConnection:Disconnect(); SpeedConnection = nil end
    if not Settings.SpeedEnabled then
        local char = AliveFolder:FindFirstChild(LocalPlayer.Name) or KillerFolder:FindFirstChild(LocalPlayer.Name)
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then humanoid.WalkSpeed = 16 end
        end
        return
    end
    local char = AliveFolder:FindFirstChild(LocalPlayer.Name) or KillerFolder:FindFirstChild(LocalPlayer.Name)
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end
    humanoid.WalkSpeed = Settings.SpeedValue
    SpeedConnection = RunService.Heartbeat:Connect(function()
        if not Settings.SpeedEnabled or not humanoid or not rootPart or humanoid.Health <= 0 then return end
        local moveDirection = humanoid.MoveDirection
        if moveDirection.Magnitude > 0.1 then
            local boostMultiplier = (Settings.SpeedValue - 16) * 0.2
            local boostForce = moveDirection * boostMultiplier
            rootPart.Velocity = Vector3.new(
                boostForce.X + rootPart.Velocity.X * 0.3,
                rootPart.Velocity.Y,
                boostForce.Z + rootPart.Velocity.Z * 0.3
            )
        end
    end)
end

local function UpdateJump()
    if JumpConnection then JumpConnection:Disconnect(); JumpConnection = nil end
    if not Settings.JumpEnabled then
        local char = LocalPlayer.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.JumpPower = 50 end
        end
