-- SAVE/LOAD FUNCTIONALITY
local SETTINGS_KEY = "GameUtilitySettings_v1"

local function SaveSettings()
    local success, err = pcall(function()
        local encoded = HttpService:JSONEncode(Settings)
        writefile(SETTINGS_KEY .. ".json", encoded)
    end)
    
    if success then
        print("[Settings] Saved successfully!")
        return true
    else
        warn("[Settings] Failed to save:", err)
        return false
    end
end

local function LoadSettings()
    local success, result = pcall(function()
        if not isfile or not isfile(SETTINGS_KEY .. ".json") then
            return nil
        end
        local data = readfile(SETTINGS_KEY .. ".json")
        return HttpService:JSONDecode(data)
    end)
    
    if success and result then
        -- Merge loaded settings with defaults (in case new settings were added)
        for key, value in pairs(DefaultSettings) do
            if result[key] == nil then
                result[key] = value
            end
        end
        Settings = result
        print("[Settings] Loaded successfully!")
        return true
    else
        -- Use default settings
        Settings = {}
        for key, value in pairs(DefaultSettings) do
            Settings[key] = value
        end
        print("[Settings] Using default settings")
        return false
    end
end

local function ResetSettings()
    Settings = {}
    for key, value in pairs(DefaultSettings) do
        Settings[key] = value
    end
    SaveSettings()
    print("[Settings] Reset to defaults")
end

-- UTILITY FUNCTIONS
local function SafeDisconnect(connection)
    if connection and typeof(connection) == "RBXScriptConnection" then
        pcall(function() connection:Disconnect() end)
    end
end

local function SafeDestroy(instance)
    if instance and typeof(instance) == "Instance" then
        pcall(function() instance:Destroy() end)
    end
end

local function CleanupConnection(name)
    if Connections[name] then
        SafeDisconnect(Connections[name])
        Connections[name] = nil
    end
end

local function CreateHighlight(obj, color)
    if not obj or not obj:IsDescendantOf(workspace) or ESPObjects[obj] then 
        return 
    end
    
    local success, highlight = pcall(function()
        local h = Instance.new("Highlight")
        h.FillColor = color
        h.FillTransparency = 0.5
        h.OutlineColor = color
        h.OutlineTransparency = 0
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Adornee = obj
        h.Parent = obj
        return h
    end)
    
    if success and highlight then
        ESPObjects[obj] = highlight
        return highlight
    end
end

local function RemoveHighlight(obj)
    local h = ESPObjects[obj]
    if h then
        SafeDestroy(h)
        ESPObjects[obj] = nil
    end
end

local function ClearHighlights()
    for obj, h in pairs(ESPObjects) do
        SafeDestroy(h)
    end
    ESPObjects = {}
end

local function GetCharacter(player)
    if not player then return nil end
    local char = player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not root or not humanoid or humanoid.Health <= 0 then return nil end
    return char
end

local function GetDistance(p1, p2)
    if not p1 or not p2 then return math.huge end
    local success, distance = pcall(function()
        return (p1.Position - p2.Position).Magnitude
    end)
    return success and distance or math.huge
end

local function IsKiller()
    local char = GetCharacter(LocalPlayer)
    if not char or not KillerFolder then return false end
    return char.Parent == KillerFolder
end

local function IsSurvivor()
    local char = GetCharacter(LocalPlayer)
    if not char or not AliveFolder then return false end
    return char.Parent == AliveFolder
end

local function GetNearestKiller()
    local char = GetCharacter(LocalPlayer)
    if not char or not KillerFolder then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local nearest = nil
    local shortest = math.huge
    
    for _, killer in ipairs(KillerFolder:GetChildren()) do
        if killer:IsA("Model") then
            local kRoot = killer:FindFirstChild("HumanoidRootPart")
            local kHum = killer:FindFirstChildOfClass("Humanoid")
            if kRoot and kHum and kHum.Health > 0 then
                local dist = GetDistance(root, kRoot)
                if dist < shortest then
                    shortest = dist
                    nearest = killer
                end
            end
        end
    end
    
    return nearest
end

local function GetNearestSurvivor()
    local char = GetCharacter(LocalPlayer)
    if not char or not AliveFolder then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local nearest = nil
    local shortest = math.huge
    
    for _, survivor in ipairs(AliveFolder:GetChildren()) do
        if survivor ~= char and survivor:IsA("Model") then
            local sRoot = survivor:FindFirstChild("HumanoidRootPart")
            local sHum = survivor:FindFirstChildOfClass("Humanoid")
            if sRoot and sHum and sHum.Health > 0 then
                local dist = GetDistance(root, sRoot)
                if dist < shortest then
                    shortest = dist
                    nearest = survivor
                end
            end
        end
    end
    
    return nearest
end

local function FireAbility(slot)
    if not WarpClient then return end
    pcall(function()
        WarpClient:Fire(true, {"Ability", slot})
    end)
end

-- ESP SYSTEM
local function UpdateESP()
    ClearHighlights()
    if not Settings.ESPEnabled then return end
    
    pcall(function()
        if Settings.SurvivorESP and AliveFolder then
            for _, s in ipairs(AliveFolder:GetChildren()) do
                if s ~= LocalPlayer.Character and s:IsA("Model") then 
                    CreateHighlight(s, Color3.fromRGB(80, 180, 255)) 
                end
            end
        end
        
        if Settings.KillerESP and KillerFolder then
            for _, k in ipairs(KillerFolder:GetChildren()) do
                if k:IsA("Model") then
                    CreateHighlight(k, Color3.fromRGB(255, 80, 80))
                end
            end
        end
        
        if Settings.GeneratorESP then
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("Model") and obj.Name == "Generator" then 
                    CreateHighlight(obj, Color3.fromRGB(0, 255, 100)) 
                end
            end
        end
        
        if Settings.BatteryESP then
            local ignore = workspace:FindFirstChild("IGNORE")
            if ignore then
                for _, obj in ipairs(ignore:GetDescendants()) do
                    if obj:IsA("MeshPart") and obj.Name == "Battery" then 
                        CreateHighlight(obj, Color3.fromRGB(255, 0, 255)) 
                    end
                end
            end
        end
        
        if Settings.FuseBoxESP then
            local maps = workspace:FindFirstChild("MAPS")
            if maps then
                local gameMap = maps:FindFirstChild("GAME MAP")
                if gameMap then
                    local tasks = gameMap:FindFirstChild("Tasks")
                    if tasks then
                        local fuseBoxes = tasks:FindFirstChild("FuseBoxes")
                        if fuseBoxes then
                            for _, fb in ipairs(fuseBoxes:GetChildren()) do
                                if fb:IsA("Model") then 
                                    CreateHighlight(fb, Color3.fromRGB(0, 255, 255)) 
                                end
                            end
                        end
                    end
                end
            end
        end
        
        if Settings.TrapESP then
            local ignore = workspace:FindFirstChild("IGNORE")
            if ignore then
                for _, obj in ipairs(ignore:GetChildren()) do
                    if obj:IsA("Model") and obj.Name:lower():find("trap") then 
                        CreateHighlight(obj, Color3.fromRGB(255, 100, 0)) 
                    end
                end
            end
        end
        
        if Settings.MinionESP then
            local ignore = workspace:FindFirstChild("IGNORE")
            if ignore then
                for _, obj in ipairs(ignore:GetDescendants()) do
                    if obj:IsA("Model") and obj.Name == "Minion" then 
                        CreateHighlight(obj, Color3.fromRGB(255, 165, 0)) 
                    end
                end
            end
        end
        
        if Settings.ItemESP then
            local items = workspace:FindFirstChild("Items")
            if items then
                for _, obj in ipairs(items:GetDescendants()) do
                    if obj:IsA("BasePart") then 
                        CreateHighlight(obj, Color3.fromRGB(255, 0, 0)) 
                    end
                end
            end
        end
    end)
end

-- SPEED SYSTEM
local function UpdateSpeed()
    CleanupConnection("Speed")
    
    -- Reset speed first
    local char = GetCharacter(LocalPlayer)
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then 
            humanoid.WalkSpeed = 16 
        end
    end
    
    if not Settings.SpeedEnabled then return end
    
    char = GetCharacter(LocalPlayer)
    if not char then return end
    
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return end
    
    humanoid.WalkSpeed = Settings.SpeedValue
    
    Connections.Speed = RunService.Heartbeat:Connect(function()
        if not Settings.SpeedEnabled then 
            CleanupConnection("Speed")
            return 
        end
        
        local currentChar = GetCharacter(LocalPlayer)
        if not currentChar then return end
        
        local currentHum = currentChar:FindFirstChildOfClass("Humanoid")
        local currentRoot = currentChar:FindFirstChild("HumanoidRootPart")
        
        if not currentHum or not currentRoot or currentHum.Health <= 0 then return end
        
        -- Reapply walkspeed if it changed
        if currentHum.WalkSpeed ~= Settings.SpeedValue then
            currentHum.WalkSpeed = Settings.SpeedValue
        end
        
        local moveDirection = currentHum.MoveDirection
        if moveDirection.Magnitude > 0.1 then
            local boostMultiplier = math.clamp((Settings.SpeedValue - 16) * 0.2, 0, 50)
            local boostForce = moveDirection * boostMultiplier
            currentRoot.Velocity = Vector3.new(
                boostForce.X + currentRoot.Velocity.X * 0.3,
                currentRoot.Velocity.Y,
                boostForce.Z + currentRoot.Velocity.Z * 0.3
            )
        end
    end)
end

