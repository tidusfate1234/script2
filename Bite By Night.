-- SERVER HOP SYSTEM
local function UpdateServerHop()
    if not Settings.ServerHop then return end
    Settings.ServerHop = false
    
    task.spawn(function()
        local servers = {}
        local success, req = pcall(function()
            return game:HttpGet("https://games.roblox.com/v1/games/" .. 
                              game.PlaceId .. 
                              "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true")
        end)
        
        if success and req then
            local decodeSuccess, body = pcall(function()
                return HttpService:JSONDecode(req)
            end)
            
            if decodeSuccess and body and body.data then
                for _, v in ipairs(body.data) do
                    if type(v) == "table" and 
                       tonumber(v.playing) and 
                       tonumber(v.maxPlayers) and 
                       v.playing < v.maxPlayers and 
                       v.id ~= game.JobId then
                        table.insert(servers, v.id)
                    end
                end
            end
        end
        
        if #servers > 0 then
            local targetServer = servers[math.random(1, #servers)]
            TeleportService:TeleportToPlaceInstance(game.PlaceId, targetServer, LocalPlayer)
        else
            warn("[Server Hop] No available servers found")
        end
    end)
end

