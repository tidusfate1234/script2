-- FLIGHT SYSTEM
local function StopFlight()
    CleanupConnection("Flight")
    
    for key, obj in pairs(FlightObjects) do
        SafeDestroy(obj)
        FlightObjects[key] = nil
    end
    
    local char = GetCharacter(LocalPlayer)
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then 
            hum.PlatformStand = false 
        end
    end
end

local function StartFlight()
    local char = GetCharacter(LocalPlayer)
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    
    StopFlight()
    
    hum.PlatformStand = true
    
    -- Create flight objects
    FlightObjects.BV = Instance.new("BodyVelocity")
    FlightObjects.BV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    FlightObjects.BV.Velocity = Vector3.zero
    FlightObjects.BV.Parent = hrp
    
    FlightObjects.BG = Instance.new("BodyGyro")
    FlightObjects.BG.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
    FlightObjects.BG.P = 1e5
    FlightObjects.BG.CFrame = hrp.CFrame
    FlightObjects.BG.Parent = hrp
    
    -- Load animations safely
    pcall(function()
        local flightAnim = Instance.new("Animation")
        flightAnim.AnimationId = "rbxassetid://15984964491"
        FlightObjects.Anim = hum:LoadAnimation(flightAnim)
        FlightObjects.Anim.Looped = true
        FlightObjects.Anim:Play()
        FlightObjects.Anim.TimePosition = 0.7
        FlightObjects.Anim:AdjustSpeed(0)
        
        local idleAnim = Instance.new("Animation")
        idleAnim.AnimationId = "rbxassetid://91428863336534"
        FlightObjects.IdleAnim = hum:LoadAnimation(idleAnim)
        FlightObjects.IdleAnim.Looped = true
    end)
    
    FlightObjects.Sound = Instance.new("Sound")
    FlightObjects.Sound.SoundId = "rbxassetid://3308152153"
    FlightObjects.Sound.Looped = true
    FlightObjects.Sound.Volume = 1
    FlightObjects.Sound.Parent = hrp
    FlightObjects.Sound:Play()
    
    local currentVel = Vector3.zero
    
    Connections.Flight = RunService.RenderStepped:Connect(function()
        if not Settings.FlightEnabled then 
            StopFlight()
            return 
        end
        
        local currentChar = GetCharacter(LocalPlayer)
        if not currentChar then 
            StopFlight()
            return 
        end
        
        local currentRoot = currentChar:FindFirstChild("HumanoidRootPart")
        if not currentRoot then 
            StopFlight()
            return 
        end
        
        local direction = Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then 
            direction = direction + Camera.CFrame.LookVector 
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then 
            direction = direction - Camera.CFrame.LookVector 
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then 
            direction = direction - Camera.CFrame.RightVector 
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then 
            direction = direction + Camera.CFrame.RightVector 
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then 
            direction = direction + Vector3.new(0, 1, 0) 
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then 
            direction = direction - Vector3.new(0, 1, 0) 
        end
        
        local targetVel = direction.Magnitude > 0 and direction.Unit * Settings.FlightSpeed or Vector3.zero
        currentVel = currentVel:Lerp(targetVel, 0.25)
        
        if FlightObjects.BV and FlightObjects.BV.Parent then 
            FlightObjects.BV.Velocity = currentVel 
        end
        
        if FlightObjects.BG and FlightObjects.BG.Parent then 
            FlightObjects.BG.CFrame = CFrame.new(currentRoot.Position, currentRoot.Position + Camera.CFrame.LookVector) 
        end
        
        -- Handle animations
        pcall(function()
            if currentVel.Magnitude < 1 then
                if FlightObjects.Anim and FlightObjects.Anim.IsPlaying then 
                    FlightObjects.Anim:Stop() 
                end
                if FlightObjects.IdleAnim and not FlightObjects.IdleAnim.IsPlaying then 
                    FlightObjects.IdleAnim:Play() 
                end
                if FlightObjects.Sound then 
                    FlightObjects.Sound.Volume = 1 
                end
            else
                if FlightObjects.IdleAnim and FlightObjects.IdleAnim.IsPlaying then 
                    FlightObjects.IdleAnim:Stop() 
                end
                if FlightObjects.Anim and not FlightObjects.Anim.IsPlaying then 
                    FlightObjects.Anim:Play()
                    FlightObjects.Anim.TimePosition = 0.7
                    FlightObjects.Anim:AdjustSpeed(0)
                end
                if FlightObjects.Sound then 
                    FlightObjects.Sound.Volume = 3 
                end
            end
        end)
    end)
end

-- NOCLIP SYSTEM
local function UpdateNoclip()
    CleanupConnection("Noclip")
    
    -- Restore collision
    local char = GetCharacter(LocalPlayer)
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then 
                part.CanCollide = true 
            end
        end
    end
    
    if not Settings.Noclip then return end
    
    Connections.Noclip = RunService.Stepped:Connect(function()
        local currentChar = GetCharacter(LocalPlayer)
        if not currentChar then return end
        
        for _, part in ipairs(currentChar:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then 
                part.CanCollide = false 
            end
        end
    end)
end

-- CLIMB WALLS SYSTEM
local function UpdateClimbWalls()
    CleanupConnection("ClimbWalls")
    if not Settings.ClimbWalls then return end
    
    Connections.ClimbWalls = RunService.RenderStepped:Connect(function()
        local char = GetCharacter(LocalPlayer)
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            local rayParams = RaycastParams.new()
            rayParams.FilterDescendantsInstances = {char}
            rayParams.FilterType = Enum.RaycastFilterType.Exclude
            
            local result = workspace:Raycast(
                hrp.Position + Vector3.new(0, 2, 0), 
                hrp.CFrame.LookVector * 2, 
                rayParams
            )
            
            if result and math.abs(result.Normal.Y) < 0.1 then
                hrp.Velocity = Vector3.new(hrp.Velocity.X, 25, hrp.Velocity.Z)
            end
        end
    end)
end

-- AUTO PARRY SYSTEM
local function UpdateAutoParry()
    CleanupConnection("AutoParry")
    if not Settings.AutoParry or not KillerFolder then return end
    
    Connections.AutoParry = RunService.Heartbeat:Connect(function()
        local char = GetCharacter(LocalPlayer)
        if not char then return end
        
        local myRoot = char:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        
        for _, killer in ipairs(KillerFolder:GetChildren()) do
            if not killer:IsA("Model") then continue end
            
            local kRoot = killer:FindFirstChild("HumanoidRootPart")
            if not kRoot then continue end
            
            if GetDistance(myRoot, kRoot) > 30 then continue end
            
            local hum = killer:FindFirstChildOfClass("Humanoid")
            if not hum then continue end
            
            for _, track in ipairs(hum:GetPlayingAnimationTracks()) do
                if track.IsPlaying and track.Animation and attackIds[track.Animation.AnimationId] then
                    FireAbility(2)
                    return
                end
            end
        end
    end)
end

-- AUTO COMBO SYSTEM
local function UpdateAutoCombo()
    CleanupConnection("AutoCombo")
    if not Settings.AutoCombo then return end
    
    local lastComboTime = 0
    
    Connections.AutoCombo = RunService.Heartbeat:Connect(function()
        if not IsKiller() then return end
        
        local currentTime = tick()
        if currentTime - lastComboTime < Settings.ComboSpeed * 2 then return end
        
        local survivor = GetNearestSurvivor()
        if not survivor then return end
        
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local sRoot = survivor:FindFirstChild("HumanoidRootPart")
        if not myRoot or not sRoot then return end
        
        if GetDistance(myRoot, sRoot) <= Settings.KillAuraRange then
            FireAbility(1)
            lastComboTime = currentTime
            task.wait(Settings.ComboSpeed)
            FireAbility(2)
        end
    end)
end

-- AUTO DODGE SYSTEM
local function UpdateAutoDodge()
    CleanupConnection("AutoDodge")
    if not Settings.AutoDodge then return end
    
    local lastDodgeTime = 0
    
    Connections.AutoDodge = RunService.Heartbeat:Connect(function()
        if not IsSurvivor() then return end
        
        local currentTime = tick()
        if currentTime - lastDodgeTime < 0.5 then return end
        
        local killer = GetNearestKiller()
        if not killer then return end
        
        local char = GetCharacter(LocalPlayer)
        if not char then return end
        
        local myRoot = char:FindFirstChild("HumanoidRootPart")
        local kRoot = killer:FindFirstChild("HumanoidRootPart")
        if not myRoot or not kRoot then return end
        
        if GetDistance(myRoot, kRoot) <= Settings.DodgeRange then
            local direction = (myRoot.Position - kRoot.Position).Unit
            myRoot.CFrame = CFrame.new(myRoot.Position + direction * 15)
            lastDodgeTime = currentTime
        end
    end)
end

-- ANTI DEATH SYSTEM (Fixed)
local function UpdateAntiDeath()
    CleanupConnection("AntiDeath")
    StateVariables.LastHealth = nil
    StateVariables.Teleported = false
    StateVariables.AntiDeathDebounce = false
    
    if StateVariables.SafePlate then
        SafeDestroy(StateVariables.SafePlate)
        StateVariables.SafePlate = nil
    end
    
    if not Settings.AntiDeath then return end
    
    Connections.AntiDeath = RunService.Heartbeat:Connect(function()
        local char = GetCharacter(LocalPlayer)
        if not char then return end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hum or not hrp then return end
        
        if not StateVariables.LastHealth then 
            StateVariables.LastHealth = hum.Health
            return 
        end
        
        -- Detect damage taken
        if hum.Health < StateVariables.LastHealth and 
           hum.Health > 0 and 
           hum.Health <= Settings.DeathThreshold and
           not StateVariables.Teleported and 
           not StateVariables.AntiDeathDebounce then
            
            StateVariables.AntiDeathDebounce = true
            StateVariables.Teleported = true
            StateVariables.LastSafePos = hrp.CFrame
            
            local pos = hrp.Position
            StateVariables.SafePlate = Instance.new("Part")
            StateVariables.SafePlate.Size = Vector3.new(50, 1, 50)
            StateVariables.SafePlate.Anchored = true
            StateVariables.SafePlate.Transparency = 0.5
            StateVariables.SafePlate.Position = pos - Vector3.new(0, 100, 0)
            StateVariables.SafePlate.Parent = workspace
            
            hrp.CFrame = CFrame.new(pos - Vector3.new(0, 95, 0))
            
            task.delay(1, function() 
                StateVariables.AntiDeathDebounce = false 
            end)
            
        -- Detect healing - return to safe position
        elseif hum.Health > StateVariables.LastHealth and 
               StateVariables.Teleported and 
               StateVariables.LastSafePos and 
               not StateVariables.AntiDeathDebounce then
            
            StateVariables.AntiDeathDebounce = true
            
            if StateVariables.SafePlate then
                SafeDestroy(StateVariables.SafePlate)
                StateVariables.SafePlate = nil
            end
            
            hrp.CFrame = StateVariables.LastSafePos
            StateVariables.LastSafePos = nil
            StateVariables.Teleported = false
            
            task.delay(1, function() 
                StateVariables.AntiDeathDebounce = false 
            end)
        end
        
        StateVariables.LastHealth = hum.Health
    end)
end

-- ANTI DOMAIN SYSTEM
local function UpdateAntiDomain()
    CleanupConnection("AntiDomain")
    if not Settings.AntiDomain then return end
    
    local lastDomainDodge = 0
    
    Connections.AntiDomain = RunService.RenderStepped:Connect(function()
        local char = GetCharacter(LocalPlayer)
        if not char then return end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local currentTime = tick()
        if currentTime - lastDomainDodge < 0.5 then return end
        
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LocalPlayer then continue end
            
            local otherChar = GetCharacter(player)
            if not otherChar then continue end
            
            local otherRoot = otherChar:FindFirstChild("HumanoidRootPart")
            local otherHum = otherChar:FindFirstChildOfClass("Humanoid")
            if not otherRoot or not otherHum then continue end
            
            local dist = GetDistance(hrp, otherRoot)
            if dist > 50 then continue end
            
            for _, track in ipairs(otherHum:GetPlayingAnimationTracks()) do
                if track.IsPlaying and track.Animation and domainIds[track.Animation.AnimationId] then
                    local direction = (hrp.Position - otherRoot.Position).Unit
                    hrp.CFrame = CFrame.new(otherRoot.Position + direction * 75)
                    lastDomainDodge = currentTime
                    return
                end
            end
        end
    end)
end

-- LOCK ON SYSTEM (Fixed)
local function UpdateLockOn()
    CleanupConnection("LockOn")
    CleanupConnection("LockOnInput")
    StateVariables.LockOnTarget = nil
    
    if not Settings.LockOn then return end
    
    Connections.LockOn = RunService.RenderStepped:Connect(function()
        if StateVariables.LockOnTarget and StateVariables.LockOnTarget.Parent then
            pcall(function()
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, StateVariables.LockOnTarget.Position)
            end)
        else
            StateVariables.LockOnTarget = nil
        end
    end)
    
    Connections.LockOnInput = UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            if StateVariables.LockOnTarget then
                StateVariables.LockOnTarget = nil
                return
            end
            
            local char = GetCharacter(LocalPlayer)
            if not char then return end
            
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if not hrp then return end
            
            local closest = nil
            local shortest = math.huge
            
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    local targetChar = GetCharacter(player)
                    if targetChar then
                        local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
                        if targetRoot then
                            local dist = GetDistance(hrp, targetRoot)
                            if dist < shortest then
                                shortest = dist
                                closest = targetRoot
                            end
                        end
                    end
                end
            end
            
            StateVariables.LockOnTarget = closest
        end
    end)
end

