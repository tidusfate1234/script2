local function CreateHighlight(obj, color)
    if not obj or ESPObjects[obj] then return end
    local h = Instance.new("Highlight")
    h.FillColor = color
    h.FillTransparency = 0.5
    h.OutlineColor = color
    h.OutlineTransparency = 0
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.Adornee = obj
    h.Parent = obj
    ESPObjects[obj] = h
    return h
end

local function RemoveHighlight(obj)
    local h = ESPObjects[obj]
    if h then
        h:Destroy()
        ESPObjects[obj] = nil
    end
end

local function ClearHighlights()
    for obj, h in pairs(ESPObjects) do
        if h then h:Destroy() end
    end
    ESPObjects = {}
end

local function GetCharacter(player)
    local char = player.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not root or not humanoid or humanoid.Health <= 0 then return nil end
    return char
end

local function GetDistance(p1, p2)
    if not p1 or not p2 then return math.huge end
    return (p1.Position - p2.Position).Magnitude
end

local function IsKiller()
    local char = LocalPlayer.Character
    if not char then return false end
    return char.Parent == KillerFolder
end

local function IsSurvivor()
    local char = LocalPlayer.Character
    if not char then return false end
    return char.Parent == AliveFolder
end

local function GetNearestKiller()
    local char = LocalPlayer.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local nearest = nil
    local shortest = math.huge
    for _, killer in ipairs(KillerFolder:GetChildren()) do
        local kRoot = killer:FindFirstChild("HumanoidRootPart")
        if kRoot then
            local dist = GetDistance(root, kRoot)
            if dist < shortest then
                shortest = dist
                nearest = killer
            end
        end
    end
    return nearest
end

local function GetNearestSurvivor()
    local char = LocalPlayer.Character
    if not char then return nil end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local nearest = nil
    local shortest = math.huge
    for _, survivor in ipairs(AliveFolder:GetChildren()) do
        if survivor ~= char then
            local sRoot = survivor:FindFirstChild("HumanoidRootPart")
            if sRoot then
                local dist = GetDistance(root, sRoot)
                if dist < shortest then
                    shortest = dist
                    nearest = survivor
                end
            end
        end
    end
    return nearest
end

local function FireAbility(slot)
