    if not tasks then 
        warn("[Complete Tasks] Tasks folder not found")
        return 
    end
    
    local gens = tasks:FindFirstChild("Gens")
    local fuses = tasks:FindFirstChild("Fuses")
    local camps = tasks:FindFirstChild("Camps")
    
    if gens then 
        local total = gens:GetAttribute("total") or 4
        gens:SetAttribute("count", total) 
        print("[Complete Tasks] Generators:", total)
    end
    
    if fuses then 
        local total = fuses:GetAttribute("total") or 4
        fuses:SetAttribute("count", total) 
        print("[Complete Tasks] Fuses:", total)
    end
    
    if camps then 
        local total = camps:GetAttribute("total") or 4
