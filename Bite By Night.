-- CLEANUP FUNCTION
local function CleanupAll()
    -- Disconnect all connections
    for name, conn in pairs(Connections) do
        SafeDisconnect(conn)
    end
    Connections = {}
    
    -- Destroy all flight objects
    for key, obj in pairs(FlightObjects) do
        SafeDestroy(obj)
    end
    FlightObjects = {}
    
    -- Clean up ESP
    ClearHighlights()
    
    -- Clean up anti-death objects
    if StateVariables.SafePlate then
        SafeDestroy(StateVariables.SafePlate)
        StateVariables.SafePlate = nil
    end
    
    print("[Cleanup] All features disabled and cleaned up")
end

