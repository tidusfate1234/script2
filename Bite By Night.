-- AUTO GENERATOR SYSTEM (Fixed)
local function AutoCompleteWires()
    local success = pcall(function()
        local genGui = LocalPlayer.PlayerGui:FindFirstChild("Gen")
        if not genGui then return end
        
        local generatorMain = genGui:FindFirstChild("GeneratorMain")
        if not generatorMain then return end
        
        local wiresStart = generatorMain:FindFirstChild("WiresStart")
        local wiresEnd = generatorMain:FindFirstChild("WiresEnd")
        local wireBoxes = generatorMain:FindFirstChild("WireBoxes")
        if not (wiresStart and wiresEnd and wireBoxes) then return end
        
        for i = 1, 4 do
            local startPoint = wiresStart:FindFirstChild(tostring(i))
            local endPoint = wiresEnd:FindFirstChild(tostring(i))
            local wireBox = wireBoxes:FindFirstChild(tostring(i))
            local wire = generatorMain:FindFirstChild(tostring(i))
            
            if startPoint and endPoint and wireBox and wire then
                local connectHitbox = wireBox:FindFirstChild("ConnectHitbox")
                if connectHitbox then
                    local absPos = generatorMain.AbsolutePosition
                    local hitboxCenter = connectHitbox.AbsolutePosition + 
                                       Vector2.yAxis * connectHitbox.AbsoluteSize.Y / 2 - absPos
                    
                    endPoint.Position = UDim2.fromOffset(hitboxCenter.X, hitboxCenter.Y)
                    
                    local startCenter = startPoint.AbsolutePosition - absPos + startPoint.AbsoluteSize / 2
                    local controlPoints = wire:GetControlPoints()
                    
                    if controlPoints and #controlPoints >= 2 then
                        controlPoints[1].Position = UDim2.fromOffset(startCenter.X, startCenter.Y)
                        controlPoints[#controlPoints].Position = UDim2.fromOffset(hitboxCenter.X, hitboxCenter.Y)
                        wire:SetControlPoints(controlPoints)
                        wire.Visible = true
                    end
                end
            end
        end
    end)
end

local function UpdateAutoGenerator()
    CleanupConnection("AutoGen")
    CleanupConnection("AutoGenFire")
    StateVariables.LastFireTime = 0
    
    if not Settings.AutoGenerator then return end
    
    Connections.AutoGen = RunService.Heartbeat:Connect(function()
        local genGui = LocalPlayer.PlayerGui:FindFirstChild("Gen")
        
        if genGui then
            local generatorMain = genGui:FindFirstChild("GeneratorMain")
            if generatorMain then
                AutoCompleteWires()
            end
            
            if not Connections.AutoGenFire then
                StateVariables.LastFireTime = tick()
                
                Connections.AutoGenFire = RunService.Heartbeat:Connect(function()
                    if not Settings.AutoGenerator then return end
                    
                    local currentTime = tick()
                    local delay = Settings.GenMode == "Blatant" and 0 or 
                                Settings.GenMode == "Silent" and 7 or 
                                Settings.GenDelay
                    
                    if currentTime - StateVariables.LastFireTime >= delay then
                        pcall(function()
                            local gui = LocalPlayer.PlayerGui:FindFirstChild("Gen")
                            if gui and gui:FindFirstChild("GeneratorMain") then
                                local args = {{Wires = true, Switches = true, Lever = true}}
                                gui.GeneratorMain.Event:FireServer(unpack(args))
                            end
                        end)
                        StateVariables.LastFireTime = currentTime
                    end
                end)
            end
        else
            CleanupConnection("AutoGenFire")
            StateVariables.LastFireTime = 0
        end
    end)
end

-- INSTANT INTERACT SYSTEM
local function UpdateInstantInteract()
    local function applyToPrompts(obj)
        pcall(function()
            for _, prompt in ipairs(obj:GetDescendants()) do
                if prompt:IsA("ProximityPrompt") then
                    if obj.Name == "FuseBox" then
                        prompt.HoldDuration = 0.75
                    else
                        prompt.HoldDuration = 0
                    end
                end
            end
        end)
    end
    
    if Settings.InstantInteract then
        -- Apply to existing objects
        for _, obj in ipairs(workspace:GetDescendants()) do
            if (obj.Name == "Generator" and obj:IsA("Model")) or 
               (obj.Name == "Battery" and obj:IsA("MeshPart")) or 
               (obj.Name == "FuseBox" and obj:IsA("Model")) then
                applyToPrompts(obj)
            end
        end
        
        -- Watch for new objects
        CleanupConnection("InstantInteract")
        Connections.InstantInteract = workspace.DescendantAdded:Connect(function(desc)
            if not Settings.InstantInteract then return end
            
            if desc:IsA("ProximityPrompt") then
                task.wait(0.1)
                local ancestor = desc:FindFirstAncestor("Generator") or 
                               desc:FindFirstAncestor("Battery") or 
                               desc:FindFirstAncestor("FuseBox")
                
                if ancestor then
                    if ancestor.Name == "FuseBox" then 
                        desc.HoldDuration = 0.75 
                    else 
                        desc.HoldDuration = 0 
                    end
                end
            end
        end)
    else
        CleanupConnection("InstantInteract")
    end
end

