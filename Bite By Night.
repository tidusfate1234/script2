local function AutoCompleteWires()
    local genGui = LocalPlayer.PlayerGui:FindFirstChild("Gen")
    if not genGui then return end
    local generatorMain = genGui:FindFirstChild("GeneratorMain")
    if not generatorMain then return end
    local wiresStart = generatorMain:FindFirstChild("WiresStart")
    local wiresEnd = generatorMain:FindFirstChild("WiresEnd")
    local wireBoxes = generatorMain:FindFirstChild("WireBoxes")
    if not (wiresStart and wiresEnd and wireBoxes) then return end
    for i = 1, 4 do
        local startPoint = wiresStart:FindFirstChild(tostring(i))
        local endPoint = wiresEnd:FindFirstChild(tostring(i))
        local wireBox = wireBoxes:FindFirstChild(tostring(i))
        local wire = generatorMain:FindFirstChild(tostring(i))
        if startPoint and endPoint and wireBox and wire then
            local connectHitbox = wireBox:FindFirstChild("ConnectHitbox")
            if connectHitbox then
                local absPos = generatorMain.AbsolutePosition
                local hitboxCenter = connectHitbox.AbsolutePosition + Vector2.yAxis * connectHitbox.AbsoluteSize.Y / 2 - absPos
                endPoint.Position = UDim2.fromOffset(hitboxCenter.X, hitboxCenter.Y)
                local startCenter = startPoint.AbsolutePosition - absPos + startPoint.AbsoluteSize / 2
                local controlPoints = wire:GetControlPoints()
                if controlPoints and #controlPoints >= 2 then
                    controlPoints[1].Position = UDim2.fromOffset(startCenter.X, startCenter.Y)
                    controlPoints[#controlPoints].Position = UDim2.fromOffset(hitboxCenter.X, hitboxCenter.Y)
                    wire:SetControlPoints(controlPoints)
                    wire.Visible = true
                end
            end
        end
    end
end

local function UpdateAutoGenerator()
    if GenConnection then GenConnection:Disconnect(); GenConnection = nil end
    if FireConnection then FireConnection:Disconnect(); FireConnection = nil end
    if not Settings.AutoGenerator then return end
    LastFireTime = 0
    GenConnection = RunService.Heartbeat:Connect(function()
        local genGui = LocalPlayer.PlayerGui:FindFirstChild("Gen")
        if genGui then
            local generatorMain = genGui:FindFirstChild("GeneratorMain")
            if generatorMain then
                AutoCompleteWires()
            end
            if not FireConnection then
                LastFireTime = tick()
                FireConnection = RunService.Heartbeat:Connect(function()
                    if not Settings.AutoGenerator then return end
                    local currentTime = tick()
                    local delay = Settings.GenMode == "Blatant" and 0 or Settings.GenMode == "Silent" and 7 or Settings.GenDelay
                    if currentTime - LastFireTime >= delay then
                        local args = {{ Wires = true, Switches = true, Lever = true }}
                        pcall(function()
                            genGui.GeneratorMain.Event:FireServer(unpack(args))
                        end)
                        LastFireTime = currentTime
                    end
                end)
            end
        else
            if FireConnection then
                FireConnection:Disconnect()
                FireConnection = nil
            end
            LastFireTime = 0
        end
    end)
end

local function UpdateInstantInteract()
    local function applyToPrompts(obj)
        for _, prompt in ipairs(obj:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") then
                if obj.Name == "FuseBox" then
                    prompt.HoldDuration = 0.05
                else
                    prompt.HoldDuration = 0
                end
            end
        end
    end
    if Settings.InstantInteract then
        for _, obj in ipairs(workspace:GetDescendants()) do
            if (obj.Name == "Generator" and obj:IsA("Model")) or (obj.Name == "Battery" and obj:IsA("MeshPart")) or (obj.Name == "FuseBox" and obj:IsA("Model")) then
                applyToPrompts(obj)
            end
        end
        workspace.DescendantAdded:Connect(function(desc)
            if not Settings.InstantInteract then return end
            if desc:IsA("ProximityPrompt") then
                local ancestor = desc:FindFirstAncestor("Generator") or desc:FindFirstAncestor("Battery") or desc:FindFirstAncestor("FuseBox")
                if ancestor then
                    if ancestor.Name == "FuseBox" then desc.HoldDuration = 0.75 else desc.HoldDuration = 0 end
                end
            end
        end)
    end
end

local function UpdateAutoBarricade()
    if BarricadeConnection then BarricadeConnection:Disconnect(); BarricadeConnection = nil end
    if not Settings.AutoBarricade then return end
    BarricadeConnection = RunService.RenderStepped:Connect(function()
        local gui = LocalPlayer:WaitForChild("PlayerGui")
        local dot = gui:FindFirstChild("Dot")
        if dot and dot:IsA("ScreenGui") and dot.Enabled then
            local container = dot:FindFirstChild("Container")
            if container then
                local frame = container:FindFirstChild("Frame")
                if frame and frame:IsA("GuiObject") then
                    frame.AnchorPoint = Vector2.new(0.5, 0.5)
                    frame.Position = UDim2.new(0.5, 0, 0.5, 0)
                end
            end
        end
    end)
end

local function UpdateFreezeTimer()
    if GAME and GAME:FindFirstChild("FROZENTIMER") then
        GAME.FROZENTIMER.Value = Settings.FreezeTimer
    end
end

local function UpdateStopMusic()
    if GAME and GAME:FindFirstChild("STOP_MUSIC_ALL") then
        GAME.STOP_MUSIC_ALL.Value = Settings.StopMusic
    end
end

local function UpdateServerHop()
    if not Settings.ServerHop then return end
    Settings.ServerHop = false
    local servers = {}
    local success, req = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true")
    end)
    if success then
        local body = HttpService:JSONDecode(req)
        if body and body.data then
            for _, v in ipairs(body.data) do
                if type(v) == "table" and tonumber(v.playing) and tonumber(v.maxPlayers) and v.playing < v.maxPlayers and v.id ~= game.JobId then
                    table.insert(servers, v.id)
                end
            end
        end
    end
    if #servers > 0 then
        TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], LocalPlayer)
    end
end

local function CompleteAllTasks()
    if not GAME then return end
    local tasks = GAME:FindFirstChild("Tasks")
    if not tasks then return end
    local gens = tasks:FindFirstChild("Gens")
    local fuses = tasks:FindFirstChild("Fuses")
    local camps = tasks:FindFirstChild("Camps")
    if gens then gens:SetAttribute("count", gens:GetAttribute("total") or 4) end
    if fuses then fuses:SetAttribute("count", fuses:GetAttribute("total") or 4) end
    if camps then camps:SetAttribute("count", camps:GetAttribute("total") or 4) end
end

