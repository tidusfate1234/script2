local function CheckWall(targetPart)
local origin = Camera.CFrame.Position
local direction = (targetPart.Position - origin).Unit * AimbotRange
local raycastParams = RaycastParams.new()
raycastParams.FilterDescendantsInstances = {Character}
raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
local raycastResult = Workspace:Raycast(origin, direction, raycastParams)
if raycastResult and raycastResult.Instance then
local hitChar = raycastResult.Instance:FindFirstAncestorOfClass("Model")
if hitChar and hitChar:FindFirstChild("Humanoid") and hitChar ~= Character then
return true
end
return false
end
return true
end
local function GetClosestEnemy()
local closestEnemy = nil
local closestDistance = math.huge
local closestFOV = math.huge
for _, player in pairs(Players:GetPlayers()) do
if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 then
local head = player.Character:FindFirstChild("Head") or player.Character.HumanoidRootPart
local screenPoint, onScreen = Camera:WorldToScreenPoint(head.Position)
if onScreen then
local mousePos = UserInputService:GetMouseLocation()
local fovDistance = (Vector2.new(screenPoint.X, screenPoint.Y) - Vector2.new(mousePos.X, mousePos.Y)).Magnitude
local distance = (Character.HumanoidRootPart.Position - head.Position).Magnitude
if fovDistance <= AimbotFOV and distance <= AimbotRange then
if CheckWall(head) then
if fovDistance < closestFOV then
closestEnemy = player
closestDistance = distance
closestFOV = fovDistance
end
end
end
end
end
end
return closestEnemy
end
local function MoveMouse(deltaX, deltaY)
pcall(function()
if mousemoverel then
mousemoverel(deltaX, deltaY)
elseif mouse_move then
mouse_move(deltaX, deltaY)
end
end)
end
local function OnAimbot()
if AimbotEnabled and Character and Character:FindFirstChild("HumanoidRootPart") then
local target = GetClosestEnemy()
if target then
LockedTarget = target
local targetHead = target.Character:FindFirstChild("Head") or target.Character.HumanoidRootPart
local targetPos = targetHead.Position
if AimbotPrediction then
local enemyVelocity = target.Character.HumanoidRootPart.Velocity
local distance = (targetPos - Character.HumanoidRootPart.Position).Magnitude
local travelTime = distance / 2500
targetPos = targetPos + (enemyVelocity * travelTime)
end
local screenPoint, onScreen = Camera:WorldToScreenPoint(targetPos)
if onScreen then
local mousePos = UserInputService:GetMouseLocation()
local targetScreen = Vector2.new(screenPoint.X, screenPoint.Y)
local currentMouse = Vector2.new(mousePos.X, mousePos.Y)
local delta = (targetScreen - currentMouse) / (AimbotSmoothness / 2)
MoveMouse(delta.X, delta.Y)
if AutoShoot and CheckWall(targetHead) then
pcall(function()
if mouse1press then
mouse1press()
task.wait(0.03)
mouse1release()
end
end)
end
end
else
LockedTarget = nil
end
end
end
