local TargetPlayer = nil
local SelectedAnimID = nil
local IsActive = false
local FollowConnection = nil

local function AddTargetButtons()
	for _, child in ipairs(TargetList:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end
	local totalHeight = 0
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			local btn = Instance.new("TextButton")
			btn.Size = UDim2.new(1, 0, 0, 28)
			btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
			btn.BorderSizePixel = 0
			btn.Text = player.Name
			btn.TextColor3 = Color3.fromRGB(255, 255, 255)
			btn.Font = Enum.Font.Gotham
			btn.TextSize = 14
			btn.Parent = TargetList
			Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
			btn.MouseButton1Click:Connect(function()
				TargetPlayer = player
				TargetText.Text = player.Name
				TargetList.Visible = false
			end)
			totalHeight = totalHeight + 30
		end
	end
	TargetList.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
end

local function AddAnimButtons()
	for _, child in ipairs(AnimList:GetChildren()) do
		if child:IsA("TextButton") then child:Destroy() end
	end
	local totalHeight = 0
	for name, id in pairs(Animations) do
		local btn = Instance.new("TextButton")
		btn.Size = UDim2.new(1, 0, 0, 28)
		btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
		btn.BorderSizePixel = 0
		btn.Text = name
		btn.TextColor3 = Color3.fromRGB(255, 255, 255)
		btn.Font = Enum.Font.Gotham
		btn.TextSize = 14
		btn.Parent = AnimList
		Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
		btn.MouseButton1Click:Connect(function()
			SelectedAnimID = id
			AnimText.Text = name
			AnimList.Visible = false
		end)
		totalHeight = totalHeight + 30
	end
	AnimList.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
end

AddTargetButtons()
AddAnimButtons()
Players.PlayerAdded:Connect(AddTargetButtons)
Players.PlayerRemoving:Connect(AddTargetButtons)

TargetDropdown.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		TargetList.Visible = not TargetList.Visible
		AnimList.Visible = false
	end
end)

AnimDropdown.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		AnimList.Visible = not AnimList.Visible
		TargetList.Visible = false
	end
end)

ToggleButton.MouseButton1Click:Connect(function()
	if not TargetPlayer or not SelectedAnimID then
		return
	end
	IsActive = not IsActive
	if IsActive then
		ToggleButton.Text = "DEACTIVATE"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
		StatusLabel.Text = "Active - " .. TargetPlayer.Name
		if FollowConnection then FollowConnection:Disconnect() end
		FollowConnection = RunService.Heartbeat:Connect(function()
			if TargetPlayer and TargetPlayer.Parent and TargetPlayer.Character and LocalPlayer.Character then
				local targetHum = TargetPlayer.Character:FindFirstChildOfClass("Humanoid")
				local targetRoot = TargetPlayer.Character:FindFirstChild("HumanoidRootPart")
				local localRoot = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
				if targetHum and targetRoot and localRoot then
					local anim = targetHum:LoadAnimation(Instance.new("Animation", targetHum))
					anim.AnimationId = SelectedAnimID
					anim:Play()
					local direction = (localRoot.Position - targetRoot.Position).Unit
					targetHum:Move(direction, true)
				end
			end
		end)
	else
		ToggleButton.Text = "ACTIVATE"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(50, 150, 50)
		StatusLabel.Text = "Inactive"
		if FollowConnection then
			FollowConnection:Disconnect()
			FollowConnection = nil
		end
	end
end)

UserInputService.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		local pos = input.Position
		if not TargetList.AbsolutePosition.X <= pos.X and pos.X <= TargetList.AbsolutePosition.X + TargetList.AbsoluteSize.X or not TargetList.AbsolutePosition.Y <= pos.Y and pos.Y <= TargetList.AbsolutePosition.Y + TargetList.AbsoluteSize.Y then
			if not TargetDropdown.AbsolutePosition.X <= pos.X and pos.X <= TargetDropdown.AbsolutePosition.X + TargetDropdown.AbsoluteSize.X or not TargetDropdown.AbsolutePosition.Y <= pos.Y and pos.Y <= TargetDropdown.AbsolutePosition.Y + TargetDropdown.AbsoluteSize.Y then
				TargetList.Visible = false
			end
		end
		if not AnimList.AbsolutePosition.X <= pos.X and pos.X <= AnimList.AbsolutePosition.X + AnimList.AbsoluteSize.X or not AnimList.AbsolutePosition.Y <= pos.Y and pos.Y <= AnimList.AbsolutePosition.Y + AnimList.AbsoluteSize.Y then
			if not AnimDropdown.AbsolutePosition.X <= pos.X and pos.X <= AnimDropdown.AbsolutePosition.X + AnimDropdown.AbsoluteSize.X or not AnimDropdown.AbsolutePosition.Y <= pos.Y and pos.Y <= AnimDropdown.AbsolutePosition.Y + AnimDropdown.AbsoluteSize.Y then
				AnimList.Visible = false
			end
		end
	end
end)
